---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import headshotPlaceholder from '../../assets/SWeblogo1.jpg';
import aboutImg1 from '../../assets/about/meandmascot_1.jpg';
import aboutImg2 from '../../assets/about/mascot_1.jpg';
import aboutImg4 from '../../assets/about/meandmascot_2.jpg';
import innovationImg from '../../assets/about/contractor-innovation.jpg';
import mascot1 from '../../assets/about/mascot_1.jpg';
import satisfactionBadge from '../../assets/badge icons/satisfaction badge.jpg';
import projectBadge from '../../assets/badge icons/badge_2.jpeg';
import meAndMascot from '../../assets/about/meandmascot_1.jpg';
import heroHuman from '../../assets/about/hero-human-inside.webp';
import spaceship from '../../assets/about/hero-human-inside.webp';
import daveMascotBottom from '../../assets/about/dave and mascot_2.jpg';

const daveHeadshot = "https://www.studiosbydave.com/lovable-uploads/d08deff8-3748-4ab1-be7c-1f0aa5062b8b.png";
---

<BaseLayout 
  title="About Us"
  description="Learn about Shelby Web Company - your local Shelby, NC web design and development studio. We build custom websites, apps, and digital solutions that drive real business growth."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-1/2 text-center md:text-left">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ About Us</p>
        <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
          About Us
        </h1>
        <p class="text-xl text-brand-sky/80 mb-8">
          Helping local business owners like YOU turn online visitors into loyal customers through strategic digital marketing and web development.
        </p>
        <div class="flex flex-wrap justify-center md:justify-start gap-4">
          <a 
            href="/contact#get-in-touch"
            class="cta-glow-shine bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light"
          >
            Start Building Together
          </a>
        </div>
      </div>
      <div class="md:w-1/2 flex justify-center">
        <div class="relative w-full max-w-sm">
          <!-- Main Shelby Hero Image -->
          <Image 
            src={headshotPlaceholder} 
            alt="Shelby Web Company Logo" 
            class="rounded-[2rem] shadow-2xl border-2 border-brand-cyan/20 w-full object-cover aspect-square transition-all duration-500" 
          />
          <!-- Spaceship/Hero Human Image overlay -->
          <div class="absolute -bottom-8 -right-8 w-40 h-40 border-4 border-brand-darkest rounded-2xl overflow-hidden shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-300">
            <Image 
              src={spaceship} 
              alt="Shelby Web Co Innovation" 
              class="w-full h-full object-cover" 
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet Dave Section -->
  <section class="py-20 px-4 bg-brand-darkest" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <div class="md:w-1/3">
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-brand-cyan to-brand-glow rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
            <Image 
              src={daveHeadshot} 
              alt="David Richardson - Founder of Shelby Web Company" 
              class="relative rounded-2xl shadow-2xl border border-white/10 w-full object-cover aspect-[4/5]"
              width={600}
              height={750}
            />
          </div>
        </div>
        <div class="md:w-2/3">
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Meet the Founder</p>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">
            Meet Dave
          </h2>
          <div class="space-y-4 text-brand-sky/80 text-lg leading-relaxed text-left">
            <p>
              David "Dave" Richardson is a seasoned technology veteran with over two decades of experience. After attending UNC Charlotte and ECPI University—where he served as President of the National Vocational Technical Honor Society—Dave began his career as a Broadband Specialist right here in Shelby with Computer Connections Inc.
            </p>
            <p>
              He later advanced into roles as a Network Engineer for various IT firms, spanning from local North Carolina companies to the deserts of Las Vegas, Nevada. This diverse background gives him a unique perspective on how technology can drive business growth at every scale.
            </p>
            <p>
              Beyond his technical expertise, Dave is a lifelong musician and Audio Mastering Engineer with over 30 years of experience in recording and production. His passion for building websites and learning code eventually led him to transition into full-time web design and development.
            </p>
            <p>
              At Shelby Web Company, Dave's mission is simple: to see your business succeed. He understands that your website isn't just a digital business card—it's a tool to grow your livelihood. When our clients are happy, everybody thrives!
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Section with Images -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Our Story</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
            Building Digital Success for Local Businesses
          </h2>
          <p class="text-brand-sky/80 mb-4">
            At Shelby Web Company (formerly <a href="https://www.studiosbydave.com" target="_blank" class="text-brand-cyan hover:underline">Studios by Dave</a>), we specialize in empowering local businesses with cutting-edge digital solutions. We focus on local service businesses, landscaping companies, solar panel installers, and many more, helping them reach their full potential through professional web design, powerful SEO, memorable branding, and innovative digital strategies.
          </p>
          <p class="text-brand-sky/80 mb-4">
            We don't just build websites – we build digital engines that get your business found, trusted, and hired. From custom branding to search engine dominance, we focus on solutions that drive real growth and measurable results.
          </p>
          <div class="mt-8">
            <h3 class="font-heading text-2xl font-bold text-white mb-4 italic">"How can we make our clients more money today?"</h3>
            <p class="text-brand-sky/70">This isn't just a catchy phrase — your success is our success, and we're committed to delivering results that directly impact your bottom line.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <Image src={aboutImg1} alt="Dave and our mascot" class="rounded-xl shadow-lg w-full h-full object-cover" />
          <Image src={aboutImg2} alt="Shelby Web Co mascot" class="rounded-xl shadow-lg w-full h-full object-cover mt-8" />
        </div>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <Image src={aboutImg4} alt="Dave and mascot together" class="rounded-xl shadow-lg w-full max-h-[400px] object-cover" />
        </div>
        <div class="bg-gradient-to-br from-brand-darkest to-brand-dark rounded-2xl p-8 border border-brand-sky/20 order-1 lg:order-2">
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">100%</p>
              <p class="text-brand-sky/70 text-sm">Growth Focused</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">20+</p>
              <p class="text-brand-sky/70 text-sm">Years Experience IT</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">24/7</p>
              <p class="text-brand-sky/70 text-sm">Support Available</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">100%</p>
              <p class="text-brand-sky/70 text-sm">Satisfaction Guaranteed</p>
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-white/5 flex justify-center">
            <Image 
              src={satisfactionBadge} 
              alt="100% Customer Satisfaction Badge" 
              class="h-24 w-auto object-contain opacity-90 hover:opacity-100 transition-opacity"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Our Mission</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Our Mission
        </h2>
        <p class="text-lg text-brand-sky/80 max-w-3xl mx-auto">
          At Shelby Web Company (formerly <a href="https://www.studiosbydave.com" target="_blank" class="text-brand-cyan hover:underline">Studios by Dave</a>), we specialize in empowering local businesses with cutting-edge digital solutions. We focus on roofing, landscaping, and solar panel companies, helping them reach their full potential through professional web design, powerful SEO, memorable branding, and innovative AI automation.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Local Focus -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Local Focus</h3>
            <p class="text-brand-sky/70 text-sm">We understand local businesses and their unique challenges.</p>
          </div>
        </div>

        <!-- Proven Results -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Proven Results</h3>
            <p class="text-brand-sky/70 text-sm">Track record of helping businesses grow their online presence.</p>
          </div>
        </div>

        <!-- Targeted Solutions -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Targeted Solutions</h3>
            <p class="text-brand-sky/70 text-sm">Customized strategies for service businesses.</p>
          </div>
        </div>

        <!-- Innovation -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.989-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Innovation</h3>
            <p class="text-brand-sky/70 text-sm">Cutting-edge AI and technology to give you the competitive edge.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-20 px-4 bg-brand-darkest" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Services</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          What We Do
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex items-start space-x-4 group p-6 rounded-2xl border border-white/5 hover:border-brand-cyan/30 transition-colors">
          <div class="w-12 h-12 bg-brand-cyan/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-brand-cyan/20 transition-colors">
            <svg class="w-6 h-6 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-white mb-2">Web Design</h3>
            <p class="text-brand-sky/70">Professional web design that converts visitors into customers.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4 group p-6 rounded-2xl border border-white/5 hover:border-brand-cyan/30 transition-colors">
          <div class="w-12 h-12 bg-brand-cyan/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-brand-cyan/20 transition-colors">
            <svg class="w-6 h-6 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-white mb-2">Local SEO</h3>
            <p class="text-brand-sky/70">Search engine optimization to dominate local search results.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4 group p-6 rounded-2xl border border-white/5 hover:border-brand-cyan/30 transition-colors">
          <div class="w-12 h-12 bg-brand-cyan/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-brand-cyan/20 transition-colors">
            <svg class="w-6 h-6 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-white mb-2">Branding</h3>
            <p class="text-brand-sky/70">Logo design and complete branding packages.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4 group p-6 rounded-2xl border border-white/5 hover:border-brand-cyan/30 transition-colors">
          <div class="w-12 h-12 bg-brand-cyan/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-brand-cyan/20 transition-colors">
            <svg class="w-6 h-6 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-white mb-2">Google Business</h3>
            <p class="text-brand-sky/70">Google My Business and review optimization.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Core Values</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Our Core Values
        </h2>
        <p class="text-lg text-brand-sky/80 max-w-3xl mx-auto">
          These fundamental principles guide everything we do at Shelby Web Company (formerly <a href="https://www.studiosbydave.com" target="_blank" class="text-brand-cyan hover:underline">Studios by Dave</a>).
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Value -->
        <div class="bg-brand-dark border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 transition-all duration-300">
          <div class="w-12 h-12 bg-amber-400/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-4">Value</h3>
          <p class="text-brand-sky/70">We deliver exceptional results that exceed your investment, ensuring every dollar spent generates meaningful returns for your business.</p>
        </div>

        <!-- Integrity -->
        <div class="bg-brand-dark border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 transition-all duration-300">
          <div class="w-12 h-12 bg-amber-400/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-4">Integrity</h3>
          <p class="text-brand-sky/70">We operate with complete honesty and transparency, building trust through consistent actions and reliable communication.</p>
        </div>

        <!-- Trust -->
        <div class="bg-brand-dark border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 transition-all duration-300">
          <div class="w-12 h-12 bg-amber-400/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-4">Trust</h3>
          <p class="text-brand-sky/70">We earn your confidence through proven expertise, dependable service, and a commitment to your long-term success.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Innovation Break Section -->
  <section class="py-12 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-white/10 group">
        <Image 
          src={innovationImg} 
          alt="Contractor Innovation and Professional Workmanship" 
          class="w-full h-[400px] object-cover object-center group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-darkest/80 via-transparent to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8">
          <p class="text-white font-heading text-2xl md:text-3xl font-bold">Innovation Meets Professionalism</p>
          <p class="text-brand-sky/80 mt-2">Equipping local businesses with the digital tools needed to lead their industry.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Non-Exclusive Agency Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ We're a Non-Exclusive Agency</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
            Your Success Is Our Success
          </h2>
          <p class="text-lg text-brand-sky/80 mb-8">
            At Shelby Web Company, we believe in building relationships, not restrictions. We're proud to be a non-exclusive agency that welcomes and caters to anyone in need of our services. Whether you're a small startup, an established business, or anywhere in between, we're here to help you succeed online.
          </p>
          <p class="text-brand-cyan font-medium mb-8">
            No exclusivity, just great results.
          </p>
        </div>
        <div class="space-y-6">
          <div class="relative w-full h-[400px]">
            <Image src={daveMascotBottom} alt="Me and Mascot" class="rounded-xl shadow-lg w-full h-full object-cover" />
            <div class="absolute -bottom-6 -left-6 w-32 h-32 border-4 border-brand-dark rounded-full overflow-hidden shadow-xl">
              <Image src={mascot1} alt="Mascot" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <Image src={heroHuman} alt="Background abstract" class="w-full h-full object-cover opacity-20 scale-105" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest/90 via-brand-dark/90 to-brand-darkest/90 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10 z-10"></div>
    
    <div class="max-w-4xl mx-auto text-center relative z-20">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Build Something GREAT?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's work together to unlock your business's full potential and create something amazing. Together, we're building something great for your business!
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
      >
        START BUILDING TOGETHER
      </a>

      <!-- Bottom Featured Badges -->
      <div class="mt-16 flex justify-center">
        <div class="relative group">
          <div class="absolute -inset-4 bg-brand-cyan/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <Image 
            src={projectBadge} 
            alt="Quality Project Badge" 
            class="relative h-32 w-auto object-contain transition-transform duration-500 group-hover:scale-110"
          />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
