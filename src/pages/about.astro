---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import headshotPlaceholder from '../../assets/SWeblogo1.jpg';
import aboutImg1 from '../../assets/about/dave and mascot_4.jpg';
import aboutImg2 from '../../assets/about/mascot_1.jpg';
import aboutImg3 from '../../assets/about/meandmascot_1.jpg';
import mascot1 from '../../assets/about/mascot_1.jpg';
import meAndMascot from '../../assets/about/meandmascot_1.jpg';
import heroHuman from '../../assets/about/hero-human-inside.webp';
---

<BaseLayout 
  title="About Us"
  description="Learn about Shelby Web Company - your local Shelby, NC web design and development studio. We build custom websites, apps, and digital solutions that drive real business growth."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-1/2 text-center md:text-left">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Who We Are</p>
        <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
          About Us
        </h1>
        <p class="text-xl text-brand-sky/80 mb-8">
          We're not just another web agency. We're your digital partners, committed to building online engines that actually work for your business. <span class="text-brand-cyan">Helping local business owners like YOU turn online visitors into loyal customers through strategic digital marketing and web development.</span>
        </p>
      </div>
      <div class="md:w-1/2 flex justify-center">
        <!-- Main Shelby Hero Image -->
        <Image 
          src={headshotPlaceholder} 
          alt="Shelby Web Company Logo" 
          class="rounded-[2rem] shadow-2xl border-2 border-brand-cyan/20 w-full max-w-sm object-cover aspect-square transition-all duration-500" 
        />
      </div>
    </div>
  </section>

  <!-- Mission Section with Images -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Our Story</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
            Building Digital Success for Local Businesses
          </h2>
          <p class="text-brand-sky/80 mb-4">
            At Shelby Web Company, we specialize in empowering local businesses with cutting-edge digital solutions. We focus on local service businesses, landscaping companies, solar panel installers, and many more, helping them reach their full potential through professional web design, powerful SEO, memorable branding, and innovative digital strategies.
          </p>
          <p class="text-brand-sky/80 mb-4">
            We don't just build websites – we build digital engines that get your business found, trusted, and hired. From custom branding to search engine dominance, we focus on solutions that drive real growth and measurable results.
          </p>
          <div class="mt-8">
            <h3 class="font-heading text-2xl font-bold text-white mb-4 italic">"How can we make our clients more money today?"</h3>
            <p class="text-brand-sky/70">This isn't just a catchy phrase — your success is our success, and we're committed to delivering results that directly impact your bottom line.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <Image src={aboutImg1} alt="Dave and our mascot" class="rounded-xl shadow-lg w-full h-full object-cover" />
          <Image src={aboutImg2} alt="Shelby Web Co mascot" class="rounded-xl shadow-lg w-full h-full object-cover mt-8" />
        </div>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <Image src={aboutImg3} alt="Dave and mascot planting a tree" class="rounded-xl shadow-lg w-full max-h-[400px] object-cover" />
        </div>
        <div class="bg-gradient-to-br from-brand-darkest to-brand-dark rounded-2xl p-8 border border-brand-sky/20 order-1 lg:order-2">
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">100+</p>
              <p class="text-brand-sky/70 text-sm">Local Businesses Served</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">5+</p>
              <p class="text-brand-sky/70 text-sm">Years Experience</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">24/7</p>
              <p class="text-brand-sky/70 text-sm">Support Available</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-cyan mb-2">100%</p>
              <p class="text-brand-sky/70 text-sm">Satisfaction Guaranteed</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Why Choose Us</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          What Sets Us Apart
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Local Focus</h3>
            <p class="text-brand-sky/70 text-sm">We understand the local market and tailor our strategies to help your business stand out in Shelby, Charlotte, and beyond.</p>
          </div>
        </div>

        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Results-Driven</h3>
            <p class="text-brand-sky/70 text-sm">We focus on metrics that matter – leads, conversions, and ROI. Every decision we make is aimed at growing your business.</p>
          </div>
        </div>

        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Affordable Pricing</h3>
            <p class="text-brand-sky/70 text-sm">Quality web services shouldn't break the bank. We offer competitive pricing with transparent costs and no hidden fees.</p>
          </div>
        </div>

        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Fast Turnaround</h3>
            <p class="text-brand-sky/70 text-sm">We respect your time. Our efficient processes ensure your project is delivered on time without compromising quality.</p>
          </div>
        </div>

        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">24/7 Support</h3>
            <p class="text-brand-sky/70 text-sm">Your success is our priority. We're always available to answer questions, make updates, and ensure your site runs smoothly.</p>
          </div>
        </div>

        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Satisfaction Guaranteed</h3>
            <p class="text-brand-sky/70 text-sm">We stand behind our work. If you're not completely satisfied, we'll make it right. Your success is our success.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Non-Exclusive Agency Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ We're a Non-Exclusive Agency</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
            Your Success Is Our Success
          </h2>
          <p class="text-lg text-brand-sky/80 mb-8">
            At Shelby Web Company, we believe in building relationships, not restrictions. We're proud to be a non-exclusive agency that welcomes and caters to anyone in need of our services. Whether you're a small startup, an established business, or anywhere in between, we're here to help you succeed online.
          </p>
          <p class="text-brand-cyan font-medium mb-8">
            No exclusivity, just great results.
          </p>
        </div>
        <div class="space-y-6">
          <div class="relative w-full h-[300px]">
            <Image src={meAndMascot} alt="Me and Mascot" class="rounded-xl shadow-lg w-full h-full object-cover" />
            <div class="absolute -bottom-6 -left-6 w-32 h-32 border-4 border-brand-dark rounded-full overflow-hidden shadow-xl">
              <Image src={mascot1} alt="Mascot" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <Image src={heroHuman} alt="Background abstract" class="w-full h-full object-cover opacity-20 scale-105" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest/90 via-brand-dark/90 to-brand-darkest/90 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10 z-10"></div>
    
    <div class="max-w-4xl mx-auto text-center relative z-20">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Build Something GREAT?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's work together to unlock your business's full potential and create something amazing. Together, we're building something great for your business!
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
      >
        START BUILDING TOGETHER
      </a>
    </div>
  </section>

</BaseLayout>
