---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import shelby1 from '../../assets/service locations/Shelby/Shelby_1.jpg';
import shelby2 from '../../assets/service locations/Shelby/Shelby_2.jpg';
import shelby3 from '../../assets/service locations/Shelby/Shelby_3.jpg';
import shelby4 from '../../assets/service locations/Shelby/Shelby_4.jpg';
import shelby5 from '../../assets/service locations/Shelby/Shelby_5.jpg';
import shelby7 from '../../assets/service locations/Shelby/Shelby_7.jpg';
import shelby8 from '../../assets/service locations/Shelby/Shelby_8.jpg';
import shelby9 from '../../assets/service locations/Shelby/Shelby_9.jpg';
---

<BaseLayout 
  title="Expert Web Design & Local SEO in Shelby, NC"
  description="Helping Shelby businesses grow with custom websites and honest local SEO. We build digital foundations that connect you with your neighbors and your community."
>

  <!-- Hero Section -->
  <section class="py-24 lg:py-40 px-4 relative bg-[#0A0A0A] overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(0,180,216,0.1),transparent_50%)]"></div>
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-brand-glow/30 bg-brand-glow/5 text-brand-glow text-sm font-bold uppercase tracking-[0.2em]">
        ✦ Local Growth for Shelby Businesses
      </div>
      <h1 class="font-heading text-6xl md:text-8xl font-black text-white mb-8 tracking-tight leading-[0.9]">
        Locally Crafted Websites <br /><span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-blue">For Shelby Businesses.</span>
      </h1>
      <p class="text-xl md:text-2xl text-brand-sky/80 mb-10 max-w-3xl mx-auto leading-relaxed">
        We build websites that tell your story and help your community find you when it matters most. No tech jargon—just <span class="text-white font-bold">honest growth</span> for local Shelby businesses.
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a 
          href="/contact"
          class="group relative inline-flex items-center justify-center bg-brand-accent text-[#0A0A0A] px-10 py-4 rounded-xl font-bold text-lg hover:bg-brand-accentLight transition-all duration-300 shadow-[0_0_20px_rgba(132,204,22,0.4)] overflow-hidden"
        >
          <span class="relative z-10">Get Your Free Strategy Session</span>
          <div class="absolute inset-0 translate-x-[-100%] group-hover:translate-x-[0%] bg-white/20 transition-transform duration-300"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-24 px-4 bg-brand-darkest border-y border-white/5">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
          Is Your Shelby Business Being <span class="text-brand-cyan">Buried by the Big Guys?</span>
        </h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Tired of paying "Rent" to Yelp and Thumbtack?</span> We help you own your leads so you stop paying for every phone call.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Invisible on Google Maps?</span> If your business isn't in the Top 3 Shelby results, you're losing customers to your competitors every single day.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">A "Ghost Town" Website?</span> A website from 2015 isn't just old—it's actively scaring away potential clients near Uptown Shelby.</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <Image src={shelby1} alt="Shelby business district" class="rounded-2xl shadow-2xl aspect-square object-cover" />
        <Image src={shelby2} alt="Local web design results" class="rounded-2xl shadow-2xl aspect-square object-cover mt-8" />
      </div>
    </div>
  </section>

  <!-- The Local Advantage (Social Proof) -->
  <section class="py-24 px-4 relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Built by Your Neighbors.</h2>
        <p class="text-brand-sky/70 max-w-2xl mx-auto text-lg">
          We're not some remote agency in Charlotte. We're right here in Shelby—helping businesses from Cleveland County to Fallston win online.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        <Image src={shelby3} alt="Uptown Shelby Projects" class="rounded-xl object-cover h-64 w-full shadow-lg" />
        <Image src={shelby4} alt="Shelby local commerce" class="rounded-xl object-cover h-64 w-full shadow-lg" />
        <Image src={shelby5} alt="Cleveland County business growth" class="rounded-xl object-cover h-64 w-full shadow-lg" />
        <Image src={shelby7} alt="Shelby digital marketing" class="rounded-xl object-cover h-64 w-full shadow-lg" />
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-accent text-4xl font-black mb-2">100%</div>
          <div class="text-white font-bold text-lg mb-2">Google Indexing</div>
          <p class="text-brand-sky/60 text-sm">We've achieved full site indexing in as little as 72 hours for local Shelby businesses.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-cyan text-4xl font-black mb-2">240%</div>
          <div class="text-white font-bold text-lg mb-2">Traffic Growth</div>
          <p class="text-brand-sky/60 text-sm">Our local SEO strategies have more than doubled impressions for contractors along W Dixon Blvd.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-blue text-4xl font-black mb-2">Top 5</div>
          <div class="text-white font-bold text-lg mb-2">Map Pack Results</div>
          <p class="text-brand-sky/60 text-sm">We specialize in moving businesses from "invisible" to the front page of Shelby Google Maps.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-24 px-4 bg-brand-darkest">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="flex-1 order-2 lg:order-1">
        <div class="grid grid-cols-2 gap-4">
          <Image src={shelby8} alt="High quality web design Shelby" class="rounded-2xl shadow-2xl aspect-[3/4] object-cover" />
          <Image src={shelby9} alt="SEO results for Shelby" class="rounded-2xl shadow-2xl aspect-[3/4] object-cover mt-12" />
        </div>
      </div>
      <div class="flex-1 order-1 lg:order-2">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-8">Websites That Work <span class="text-brand-accent">As Hard As You Do.</span></h2>
        <div class="space-y-10">
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Represent Your Business with Pride</h3>
            <p class="text-brand-sky/70 leading-relaxed">In a town where reputation is everything, your website shouldn't just exist—it should speak for you. We build clean, professional sites that capture the personality of your business and turn "just looking" into "ready to hire."</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Be the First Call in Cleveland County</h3>
            <p class="text-brand-sky/70 leading-relaxed">When someone in Shelby needs a professional, they don't look at a phone book—they look at their map. We position your business so you're the first name they see when they're ready to get to work.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-3">The Last Website You'll Ever Need</h3>
            <p class="text-brand-sky/70 leading-relaxed">We don't do "one-and-done" projects. We build on a solid foundation that grows with your business, providing the technical support and local expertise you need to stay ahead of the curve as Shelby continues to grow.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 px-4 relative overflow-hidden bg-brand-accent/90" data-animate>
    <div class="max-w-4xl mx-auto text-center relative z-10 text-[#0A0A0A]">
      <h2 class="font-heading text-5xl md:text-6xl font-black mb-8 leading-tight">
        Let's Build Something <br />Great Together.
      </h2>
      <p class="text-xl md:text-2xl font-medium mb-10 opacity-90 text-balance">
        Ready to take the next step? We’re here to help your Shelby business shine online. Let’s chat about how we can help you grow.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact"
          class="inline-block bg-[#0A0A0A] text-white px-10 py-4 rounded-xl font-black text-xl hover:scale-105 transition-all duration-300 shadow-2xl"
        >
          Book a Free Chat
        </a>
        <a 
          href="tel:+17044738188"
          class="inline-block border-2 border-[#0A0A0A] text-[#0A0A0A] px-10 py-4 rounded-xl font-black text-xl hover:bg-[#0A0A0A] hover:text-white transition-all duration-300"
        >
          (704) 473-8188
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

</BaseLayout>
