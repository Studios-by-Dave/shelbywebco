---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Web Design Shelby, NC | Shelby Web Company"
  description="Professional web design services in Shelby, NC. Custom websites, local SEO, and digital marketing for Shelby businesses. Get found online and grow your business."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Shelby, NC</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Web Design in Shelby, NC
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Your local web design experts. We build custom websites that help Shelby businesses get found, trusted, and hired.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Why Shelby Businesses Choose Us</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Local Experts, Local Results
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Based in Shelby</h3>
          <p class="text-brand-sky/70 text-sm">We're your neighbors. We understand the Shelby market and what local businesses need to succeed online.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Local SEO Experts</h3>
          <p class="text-brand-sky/70 text-sm">Dominate local search results. We optimize your site to appear in Google Maps and local searches for Shelby.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Affordable Pricing</h3>
          <p class="text-brand-sky/70 text-sm">Quality web design at prices Shelby businesses can afford. No hidden fees, transparent pricing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Our Services</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          What We Offer Shelby Businesses
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Custom Web Design</h3>
          <p class="text-brand-sky/70 mb-4">Beautiful, responsive websites designed specifically for your Shelby business. No templates, just custom design that converts.</p>
          <a href="/services/web-design" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Local SEO</h3>
          <p class="text-brand-sky/70 mb-4">Get found by local customers searching for your services in Shelby. We optimize for Google Maps and local search.</p>
          <a href="/services/seo" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Logo Design & Branding</h3>
          <p class="text-brand-sky/70 mb-4">Professional branding that makes your Shelby business stand out. Logos, business cards, and complete brand identity.</p>
          <a href="/services/branding" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Digital Marketing</h3>
          <p class="text-brand-sky/70 mb-4">Complete digital marketing solutions to help your Shelby business grow online and attract more customers.</p>
          <a href="/contact#get-in-touch" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Grow Your Shelby Business?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's build a website that drives real results for your business. Get in touch today for a free consultation.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
