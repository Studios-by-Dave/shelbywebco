---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import ashHead from '../../assets/service locations/asheville/Asheville nc_header1.jpg';
import ash2 from '../../assets/service locations/asheville/Asheville nc_2.jpeg';
import ash5 from '../../assets/service locations/asheville/Asheville nc_5.jpg';
import ash6 from '../../assets/service locations/asheville/asheville nc_6.jpeg';
import ash7 from '../../assets/service locations/asheville/Asheville_6.jpeg';
---

<BaseLayout 
  title="Expert Web Design & Local SEO in Asheville, NC"
  description="Helping Asheville businesses grow with custom websites and honest local SEO. We build digital foundations that connect you with your neighbors across the mountains."
>

  <!-- Hero Section -->
  <section class="py-24 lg:py-40 px-4 relative bg-[#0A0A0A] overflow-hidden" data-animate>
    <div class="hero-background-image absolute inset-0 z-0 opacity-40">
      <Image src={ashHead} alt="Asheville, NC Background" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0A0A]/65 via-[#0A0A0A]/70 to-[#0A0A0A] z-0"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(0,180,216,0.1),transparent_50%)] z-0"></div>
    
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-brand-glow/30 bg-brand-glow/5 text-brand-glow text-sm font-bold uppercase tracking-[0.2em]">
        ✦ Local Growth for Asheville Businesses
      </div>
      <h1 class="font-heading text-6xl md:text-8xl font-black text-white mb-8 tracking-tight leading-[0.9]">
        Elevating Mountain Brands <br /><span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-blue">Across Asheville.</span>
      </h1>
      <p class="text-xl md:text-2xl text-brand-sky/80 mb-10 max-w-3xl mx-auto leading-relaxed">
        From downtown to the Blue Ridge valleys, we specialize in high-performance web design and SEO campaigns tailored for <span class="text-white font-bold">local impact</span>.
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a 
          href="/contact"
          class="group relative inline-flex items-center justify-center bg-brand-accent text-[#0A0A0A] px-10 py-4 rounded-xl font-bold text-lg hover:bg-brand-accent-light transition-all duration-300 shadow-[0_0_20px_rgba(132,204,22,0.4)] overflow-hidden"
        >
          <span class="relative z-10">Get Your Free Strategy Session</span>
          <div class="absolute inset-0 translate-x-[-100%] group-hover:translate-x-[0%] bg-white/20 transition-transform duration-300"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-24 px-4 bg-brand-darkest border-y border-white/5">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
          Is Your Asheville Presence <span class="text-brand-cyan">Falling Behind?</span>
        </h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Spending too much on directory leads?</span> Break free from shared platforms and start generating your own exclusive inquiries.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Missing from local map searches?</span> When potential clients look for services nearby, your business needs to appear at the absolute top.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Outdated digital storefront?</span> A clunky, slow website makes it harder for customers to trust your brand before they even reach out.</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <Image src={ash2} alt="Asheville business district" class="rounded-2xl shadow-2xl aspect-square object-cover" />
        <Image src={ash7} alt="Local results in Asheville" class="rounded-2xl shadow-2xl aspect-square object-cover mt-8" />
      </div>
    </div>
  </section>

  <!-- The Local Advantage (Social Proof) -->
  <section class="py-24 px-4 relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Rooted in Western NC.</h2>
        <p class="text-brand-sky/70 max-w-2xl mx-auto text-lg">
          We understand the specific market dynamics of the mountains. Our regional expertise translates to campaigns that genuinely connect.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        <Image src={ash6} alt="Asheville Projects" class="rounded-xl object-cover h-64 w-full shadow-lg" />
        <Image src={ash5} alt="Asheville local commerce" class="rounded-xl object-cover h-64 w-full shadow-lg" />
        <Image src={ashHead} alt="Western NC business growth" class="rounded-xl object-cover h-64 w-full shadow-lg" />
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-accent text-4xl font-black mb-2">100%</div>
          <div class="text-white font-bold text-lg mb-2">Visibility Focus</div>
          <p class="text-brand-sky/60 text-sm">We optimize site infrastructure so local customers find you immediately.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-cyan text-4xl font-black mb-2">Steady</div>
          <div class="text-white font-bold text-lg mb-2">Lead Generation</div>
          <p class="text-brand-sky/60 text-sm">Our modern layouts keep bounce rates low and conversions flowing consistently.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-blue text-4xl font-black mb-2">Local</div>
          <div class="text-white font-bold text-lg mb-2">Search Authority</div>
          <p class="text-brand-sky/60 text-sm">We ensure directories and maps properly align to establish regional trust.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-24 px-4 bg-brand-darkest">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="flex-1 order-2 lg:order-1">
        <div class="grid grid-cols-2 gap-4">
          <Image src={ashHead} alt="High quality web design Asheville" class="rounded-2xl shadow-2xl aspect-[3/4] object-cover" />
          <Image src={ash2} alt="SEO results for Asheville" class="rounded-2xl shadow-2xl aspect-[3/4] object-cover mt-12" />
        </div>
      </div>
      <div class="flex-1 order-1 lg:order-2">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-8">Digital Strategy Designed <span class="text-brand-accent">For Growth.</span></h2>
        <div class="space-y-10">
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Modernize Your Brand Identity</h3>
            <p class="text-brand-sky/70 leading-relaxed">It's critical that your online storefront instills trust from the first click. We design streamlined, fast-loading sites that elevate your company's perceived value right away.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Capture High-Intent Traffic</h3>
            <p class="text-brand-sky/70 leading-relaxed">When potential clients across Asheville search for solutions, we strategically position your site to capture those ready-to-buy visitors.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Long-Term Partnerships</h3>
            <p class="text-brand-sky/70 leading-relaxed">We view our client relationships as ongoing collaborations. As the digital landscape evolves, we continually optimize to keep your operations scaling effectively.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 px-4 relative overflow-hidden bg-brand-accent/90" data-animate>
    <div class="max-w-4xl mx-auto text-center relative z-10 text-[#0A0A0A]">
      <h2 class="font-heading text-5xl md:text-6xl font-black mb-8 leading-tight">
        Secure Your Space <br />At The Top.
      </h2>
      <p class="text-xl md:text-2xl font-medium mb-10 opacity-90 text-balance">
        Start dominating local traffic in Asheville today. Schedule a brief consultation to explore the right strategy for your goals.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact"
          class="inline-block bg-[#0A0A0A] text-white px-10 py-4 rounded-xl font-black text-xl hover:scale-105 transition-all duration-300 shadow-2xl"
        >
          Book a Free Chat
        </a>
        <a 
          href="tel:+17044738188"
          class="inline-block border-2 border-[#0A0A0A] text-[#0A0A0A] px-10 py-4 rounded-xl font-black text-xl hover:bg-[#0A0A0A] hover:text-white transition-all duration-300"
        >
          (704) 473-8188
        </a>
      </div>
    </div>
  </section>

  <style>
    .hero-background-image {
      -webkit-mask-image: linear-gradient(
        to bottom,
        black 0%,
        black 48%,
        rgba(0, 0, 0, 0.8) 68%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to bottom,
        black 0%,
        black 48%,
        rgba(0, 0, 0, 0.8) 68%,
        transparent 100%
      );
    }
  </style>

</BaseLayout>
