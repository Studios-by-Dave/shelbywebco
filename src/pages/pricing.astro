---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Pricing"
  description="Transparent web design pricing with clear ranges. From simple brochure sites to enterprise solutions - know what to expect before we start."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-7xl mx-auto text-center">
      <p class="text-brand-purple text-sm uppercase tracking-widest mb-4">✦ Transparent Pricing</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blueLight to-brand-sky">We Build</span> More Than Just <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blueLight to-brand-sky">Websites</span>
      </h1>
      <p class="text-xl text-white/80 max-w-3xl mx-auto">
        Clear price ranges for every project. No hidden fees, no surprises — just honest pricing that scales with your needs.
      </p>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        
        <!-- Starter Package -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Starter Website</h3>
          <p class="text-white/60 text-sm mb-6 italic">Simple brochure sites</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-brand-accent text-sm font-bold uppercase tracking-wider mb-1 animate-pulse">Now ONLY</span>
              <span class="text-4xl md:text-5xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">$598</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 1-2 page brochure site</li>
            <li>• Mobile-responsive design</li>
            <li>• Contact form included</li>
            <li>• Basic SEO setup</li>
            <li>• 1 revision round</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center"
          >
            Get Started
          </a>
        </div>

        <!-- Business Package -->
        <div class="bg-gradient-to-br from-[#111111] via-brand-darkest to-brand-dark border border-[#f3db70]/50 rounded-2xl p-8 shadow-[inset_0_2px_2px_rgba(255,255,255,0.15),_0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[inset_0_2px_2px_rgba(255,255,255,0.2),_0_25px_50px_rgba(0,0,0,0.7),_0_0_40px_rgba(243,219,112,0.25)] transition-all duration-300 relative z-10 scale-100 lg:scale-105">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#f3db70] text-[#0A0A0A] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider drop-shadow-md">
            Most Popular
          </div>
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Business Web Package</h3>
          <p class="text-white/60 text-sm mb-6 italic">Standard business sites</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">$998 - $1,998</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 3-5 page business site</li>
            <li>• Custom design & branding</li>
            <li>• Advanced contact forms</li>
            <li>• Local SEO optimization</li>
            <li>• 2 revision rounds</li>
            <li>• Analytics integration</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-accent text-[#0A0A0A] px-6 py-3 rounded-lg font-medium hover:bg-brand-accentLight transition-all duration-300 text-center shadow-[0_0_15px_rgba(132,204,22,0.3)]"
          >
            Get Started
          </a>
        </div>

        <!-- Scale Package -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Scale Web Package</h3>
          <p class="text-white/60 text-sm mb-6 italic">Multi-service or locations</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">$2,000 - $3,998</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 6-10 page site</li>
            <li>• Advanced functionality</li>
            <li>• Booking/appointment system</li>
            <li>• E-commerce ready</li>
            <li>• Custom integrations</li>
            <li>• 3 revision rounds</li>
            <li>• Priority support</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center"
          >
            Get Started
          </a>
        </div>

        <!-- Enterprise Package -->
        <div class="bg-gradient-to-br from-[#151515] via-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Enterprise</h3>
          <p class="text-white/60 text-sm mb-6 italic">Complex custom solutions</p>
          
          <div class="mb-6">
            <div class="text-center min-h-[4rem] flex items-center justify-center">
              <span class="text-2xl md:text-3xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">Contact For Quote</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 10+ pages</li>
            <li>• Custom web applications</li>
            <li>• Membership portals</li>
            <li>• Advanced CRM integrations</li>
            <li>• Custom API development</li>
            <li>• Unlimited revisions</li>
            <li>• Dedicated account manager</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full border-2 border-brand-purple text-brand-purple px-6 py-3 rounded-lg font-medium hover:bg-brand-purple hover:text-white transition-all duration-300 text-center"
          >
            Book Discovery Call
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- What Affects Pricing Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-4xl mx-auto">
      <p class="text-brand-purple text-sm uppercase tracking-widest mb-4">✦ What Affects Your Price</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-8">
        Understanding the Range
      </h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-brand-darkest border border-brand-purple/20 rounded-xl p-6">
          <h3 class="text-brand-green font-bold mb-2">Lower End of Range</h3>
          <p class="text-white/70 text-sm">
            Simple layouts, existing branding/content ready, standard features, no custom integrations, flexible timeline.
          </p>
        </div>
        
        <div class="bg-brand-darkest border border-brand-purple/20 rounded-xl p-6">
          <h3 class="text-brand-purple font-bold mb-2">Higher End of Range</h3>
          <p class="text-white/70 text-sm">
            Custom design from scratch, complex functionality, multiple integrations, rush timeline, extensive content creation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Monthly Website Care Plans Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Monthly Website Care Plans</h2>
        <p class="text-xl text-white/80 max-w-2xl mx-auto">
          Keep your investment secure, fast, and running smoothly with our ongoing maintenance and support plans.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        
        <!-- Standard Plan -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Website Care Plan - Standard</h3>
          <p class="text-white/60 text-sm mb-6 italic">Essential maintenance and security</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-4xl md:text-5xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">$75<span class="text-lg text-white/60 font-normal">/mo</span></span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• Premium Web Hosting</li>
            <li>• Daily Cloud Backups</li>
            <li>• Core CMS & Plugin Updates</li>
            <li>• 24/7 Security Scanning</li>
            <li>• Uptime Monitoring</li>
            <li>• Monthly Performance Report</li>
            <li>• Email Support</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center"
          >
            Select Standard Plan
          </a>
        </div>

        <!-- Premium Plan -->
        <div class="bg-gradient-to-br from-[#111111] via-brand-darkest to-brand-dark border border-[#f3db70]/50 rounded-2xl p-8 shadow-[inset_0_2px_2px_rgba(255,255,255,0.15),_0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[inset_0_2px_2px_rgba(255,255,255,0.2),_0_25px_50px_rgba(0,0,0,0.7),_0_0_40px_rgba(243,219,112,0.25)] transition-all duration-300 relative z-10 scale-100 lg:scale-105">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[linear-gradient(110deg,#f3db70,45%,#fff,55%,#9b7b2a)] bg-[length:200%_auto] animate-shine text-[#0A0A0A] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider drop-shadow-md">
            Recommended
          </div>
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Premium Website Care Plan</h3>
          <p class="text-white/60 text-sm mb-6 italic">Comprehensive care & content updates</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-4xl md:text-5xl font-black font-nav bg-[linear-gradient(110deg,#f3db70,45%,#fff,55%,#9b7b2a)] bg-[length:200%_auto] animate-shine bg-clip-text text-transparent drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">$149<span class="text-lg text-white/60 font-normal">/mo</span></span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• Premium Web Hosting</li>
            <li>• Real-time Cloud Backups</li>
            <li>• Core CMS & Plugin Updates</li>
            <li>• Advanced Malware Protection</li>
            <li>• Uptime & Performance Monitoring</li>
            <li>• Detailed Monthly Reports</li>
            <li>• <strong>1 Hour of Code Revisions/mo</strong></li>
            <li>• Priority Email & Phone Support</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-accent text-[#0A0A0A] px-6 py-3 rounded-lg font-medium hover:bg-brand-accentLight transition-all duration-300 text-center shadow-[0_0_15px_rgba(132,204,22,0.3)]"
          >
            Select Premium Plan
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-4xl mx-auto">
      <p class="text-brand-purple text-sm uppercase tracking-widest mb-4 text-center">✦ FAQ</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-12 text-center">
        Frequently Asked Questions
      </h2>

      <div class="space-y-4" id="pricing-faq">
        <!-- Question 1 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">What's included in the price?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Every package includes custom design, mobile responsiveness, basic SEO setup, and a contact form. Higher-tier packages add advanced functionality like booking systems, e-commerce, analytics integration, and more. All packages include hosting setup assistance and a domain consultation.
            </div>
          </div>
        </div>

        <!-- Question 2 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">Do you offer payment plans?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Yes! We offer flexible payment plans for most packages. Typically we require 50% upfront to begin the project, with the remaining balance due upon completion. For larger projects, we can arrange monthly installments — just ask during your consultation.
            </div>
          </div>
        </div>

        <!-- Question 3 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">How long does a typical project take?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Most projects are completed within 2–4 weeks, depending on the scope. A simple 1–2 page site can be ready in as little as 1–2 weeks, while more complex builds (e-commerce, custom portals) typically take 4–6 weeks. We'll give you a clear timeline during the proposal phase.
            </div>
          </div>
        </div>

        <!-- Question 4 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">What if I need more pages than my package includes?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              No problem! Additional pages beyond the package limit are billed at a flat rate of $75–$150 per page, depending on complexity. We can also help you prioritize which pages to launch with and add more later as your business grows.
            </div>
          </div>
        </div>

        <!-- Question 5 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">Do you handle hosting and domain setup?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Yes, we handle the full setup. We'll help you choose a domain, configure hosting (or recommend the best provider for your needs), and get everything deployed. Hosting fees are separate and typically range from $10–$30/month depending on your provider and plan.
            </div>
          </div>
        </div>

        <!-- Question 6 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">Can I upgrade my package later?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Absolutely. Your site is built on a scalable foundation, so upgrading is smooth. Whether you need to add e-commerce, a booking system, or more pages down the road, we can handle it. We'll simply quote the additional work based on your current package rate.
            </div>
          </div>
        </div>

        <!-- Question 7 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">What if I'm not satisfied with the design?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Your satisfaction matters. Every package includes 1–3 revision rounds (depending on the tier) where you can request changes. We work iteratively, sharing progress along the way so there are no surprises. For Enterprise clients, we offer unlimited revisions until everything is perfect.
            </div>
          </div>
        </div>

        <!-- Question 8 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">Do you offer ongoing maintenance?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Yes! We offer optional maintenance plans starting at $49/month for smaller sites. This includes security updates, regular backups, uptime monitoring, content updates, and priority support. It's a great way to keep your site running smoothly without worrying about the technical details.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Not Sure Which Package You Need?
      </h2>
      <p class="text-lg text-white/80 mb-8">
        Let's chat about your project. We'll help you find the right fit and give you a custom quote within your range.
      </p>
      <a 
        href="/contact#get-in-touch" 
        class="inline-block bg-brand-green text-white px-8 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300"
      >
        Schedule a Free Consultation
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  // FAQ Accordion Toggle
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question') as HTMLElement | null;
      const answer = item.querySelector('.faq-answer') as HTMLElement | null;
      const icon = item.querySelector('.faq-icon') as HTMLElement | null;

      if (!question || !answer || !icon) return;

      question.addEventListener('click', () => {
        const isOpen = item.classList.contains('active');

        // Close all FAQ items
        faqItems.forEach(otherItem => {
          otherItem.classList.remove('active');
          const otherQuestion = otherItem.querySelector('.faq-question') as HTMLElement | null;
          const otherAnswer = otherItem.querySelector('.faq-answer') as HTMLElement | null;
          const otherIcon = otherItem.querySelector('.faq-icon') as HTMLElement | null;
          if (otherQuestion) otherQuestion.setAttribute('aria-expanded', 'false');
          if (otherAnswer) otherAnswer.style.maxHeight = '0';
          if (otherIcon) {
            otherIcon.textContent = '+';
            otherIcon.style.transform = 'rotate(0deg)';
          }
        });

        // If it was closed, open it
        if (!isOpen) {
          item.classList.add('active');
          question.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          icon.textContent = '−';
          icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
</script>
