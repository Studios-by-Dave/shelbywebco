---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Pricing"
  description="Transparent web design pricing with clear ranges. From simple brochure sites to enterprise solutions - know what to expect before we start."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-7xl mx-auto text-center">
      <p class="text-brand-purple text-sm uppercase tracking-widest mb-4">✦ Transparent Pricing</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blue-light to-brand-sky">We Build</span> More Than Just <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blue-light to-brand-sky">Websites</span>
      </h1>
      <p class="text-xl text-white/80 max-w-3xl mx-auto">
        Clear price ranges for every project. No hidden fees, no surprises — just honest pricing that scales with your needs.
      </p>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        
        <!-- Starter Package -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Starter Website</h3>
          <p class="text-white/60 text-sm mb-6 italic">Simple brochure sites</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-brand-accent text-sm font-bold uppercase tracking-wider mb-1 animate-pulse">Now ONLY</span>
              <span class="text-4xl md:text-5xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$598</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 1-3 page brochure site</li>
            <li>• Mobile-responsive design</li>
            <li>• Contact form included</li>
            <li>• Basic SEO setup</li>
            <li>• 1 revision round</li>
            <li class="text-brand-accent/80 italic">• Does not include web hosting</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center"
          >
            Get Started
          </a>
        </div>

        <!-- Business Package -->
        <div class="bg-gradient-to-br from-[#111111] via-brand-darkest to-brand-dark border border-[#f3db70]/50 rounded-2xl p-8 shadow-[inset_0_2px_2px_rgba(255,255,255,0.15),_0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[inset_0_2px_2px_rgba(255,255,255,0.2),_0_25px_50px_rgba(0,0,0,0.7),_0_0_40px_rgba(243,219,112,0.25)] transition-all duration-300 relative z-10 scale-100 lg:scale-105">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#f3db70] text-[#0A0A0A] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider drop-shadow-md">
            Most Popular
          </div>
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Business Web Package</h3>
          <p class="text-white/60 text-sm mb-6 italic">Standard business sites</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$998 - $1,998</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 3-5 page business site</li>
            <li>• Custom design & branding</li>
            <li>• Advanced contact forms</li>
            <li>• Local SEO optimization</li>
            <li>• 2 revision rounds</li>
            <li>• <strong>Web Hosting Included</strong></li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="cta-glow-shine block w-full bg-brand-accent text-[#0A0A0A] px-6 py-3 rounded-lg font-medium hover:bg-brand-accent-light text-center"
          >
            Get Started
          </a>
        </div>

        <!-- Scale Package -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Scale Web Package</h3>
          <p class="text-white/60 text-sm mb-6 italic">The Ultimate Business Engine</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$2,500 - $4,998</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 6-10+ page Business Engine</li>
            <li>• Full Blog Integration & Content</li>
            <li>• CRM Integration (Hubspot, etc.)</li>
            <li>• <strong>Premium Care Plan Included</strong></li>
            <li>• <strong>Web Hosting Included</strong></li>
            <li>• Advanced booking or E-commerce</li>
            <li>• Unlimited Marketing Capability</li>
            <li>• Priority support</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center"
          >
            Get Started
          </a>
        </div>

        <!-- Enterprise Package -->
        <div class="bg-gradient-to-br from-[#151515] via-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Enterprise</h3>
          <p class="text-white/60 text-sm mb-6 italic">Complex custom solutions</p>
          
          <div class="mb-6">
            <div class="text-center min-h-[4rem] flex items-center justify-center">
              <span class="text-2xl md:text-3xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">Contact For Quote</span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 10+ pages</li>
            <li>• Custom web applications</li>
            <li>• Membership portals</li>
            <li>• Advanced CRM integrations</li>
            <li>• Custom API development</li>
            <li>• Unlimited revisions</li>
            <li>• Dedicated account manager</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full border-2 border-brand-purple text-brand-purple px-6 py-3 rounded-lg font-medium hover:bg-brand-purple hover:text-white transition-all duration-300 text-center"
          >
            Book Discovery Call
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- What Affects Pricing Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-4xl mx-auto">
      <p class="text-brand-purple text-sm uppercase tracking-widest mb-4">✦ What Affects Your Price</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-8">
        Understanding the Range
      </h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-brand-darkest border border-brand-purple/20 rounded-xl p-6">
          <h3 class="text-brand-green font-bold mb-2">Lower End of Range</h3>
          <p class="text-white/70 text-sm">
            Simple layouts, existing branding/content ready, standard features, no custom integrations, flexible timeline.
          </p>
        </div>
        
        <div class="bg-brand-darkest border border-brand-purple/20 rounded-xl p-6">
          <h3 class="text-brand-purple font-bold mb-2">Higher End of Range</h3>
          <p class="text-white/70 text-sm">
            Custom design from scratch, complex functionality, multiple integrations, rush timeline, extensive content creation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Monthly Website Care Plans Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Monthly Website Care Plans</h2>
        <p class="text-xl text-white/80 max-w-2xl mx-auto">
          Keep your investment secure, fast, and running smoothly with our ongoing maintenance and support plans.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        
        <!-- Standard Plan -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Website Care Plan - Standard</h3>
          <p class="text-white/60 text-sm mb-6 italic">Secure web hosting & maintenance</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-4xl md:text-5xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$75<span class="text-lg text-white/60 font-normal">/mo</span></span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• Premium Web Hosting</li>
            <li>• Backups & Core Updates</li>
            <li>• Image & Text Revisions</li>
            <li>• 24/7 Security Scanning</li>
            <li>• Performance Optimization</li>
            <li>• Uptime Monitoring</li>
            <li>• Email Support</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center"
          >
            Select Standard Plan
          </a>
        </div>

        <!-- Premium Plan -->
        <div class="bg-gradient-to-br from-[#111111] via-brand-darkest to-brand-dark border border-[#f3db70]/50 rounded-2xl p-8 shadow-[inset_0_2px_2px_rgba(255,255,255,0.15),_0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[inset_0_2px_2px_rgba(255,255,255,0.2),_0_25px_50px_rgba(0,0,0,0.7),_0_0_40px_rgba(243,219,112,0.25)] transition-all duration-300 relative z-10 scale-100 lg:scale-105">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[linear-gradient(110deg,#f3db70,45%,#fff,55%,#9b7b2a)] bg-[length:200%_auto] animate-shine text-[#0A0A0A] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider drop-shadow-md">
            Recommended
          </div>
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Premium Website Care Plan</h3>
          <p class="text-white/60 text-sm mb-6 italic">Everything for tip-top performance</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-4xl md:text-5xl font-black font-nav bg-[linear-gradient(110deg,#f3db70,45%,#fff,55%,#9b7b2a)] bg-[length:200%_auto] animate-shine bg-clip-text text-transparent drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">$149<span class="text-lg text-white/60 font-normal">/mo</span></span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• Premium Web Hosting</li>
            <li>• Daily Backups & Core Updates</li>
            <li>• **Unlimited Image/Text Revisions**</li>
            <li>• Advanced Malware Protection</li>
            <li>• Performance & SEO Monitoring</li>
            <li>• Priority Support</li>
            <li>• <strong>1 Hour of Code Development/mo</strong></li>
            <li>• Detailed Monthly Reports</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="cta-glow-shine block w-full bg-brand-accent text-[#0A0A0A] px-6 py-3 rounded-lg font-medium hover:bg-brand-accent-light text-center"
          >
            Select Premium Plan
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ROI Calculator Section -->
  <section class="py-24 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-cyan/20 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-brand-cyan/20 to-transparent"></div>
    
    <div class="max-w-4xl mx-auto relative z-10">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-[0.2em] mb-4">✦ Growth Forecasting</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">ROI Calculator</h2>
        <p class="text-lg text-brand-sky/70">
          See the real impact a high-performing website has on your bottom line. 
          <span class="text-white font-semibold">Invest in growth, not just code.</span>
        </p>
      </div>

      <div class="bg-brand-dark/50 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <!-- Inputs -->
          <div class="space-y-8">
            <div class="space-y-4">
              <label class="block text-white font-bold text-lg mb-2">Average Customer Value (LTV)</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-brand-sky/50 font-bold">$</span>
                <input 
                  type="number" 
                  id="avgValue" 
                  value="1500" 
                  class="w-full bg-brand-darkest border border-white/10 rounded-xl py-4 pl-10 pr-4 text-white font-bold focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan outline-none transition-all"
                />
              </div>
              <p class="text-xs text-brand-sky/50 italic">Total revenue from one customer over their lifetime.</p>
            </div>

            <div class="space-y-4">
              <label class="block text-white font-bold text-lg mb-2">Estimated New Monthly Leads</label>
              <input 
                type="range" 
                id="newLeads" 
                min="1" 
                max="50" 
                value="5" 
                class="w-full accent-brand-cyan"
              />
              <div class="flex justify-between text-brand-sky/70 font-mono text-sm">
                <span>1 Lead</span>
                <span class="text-white font-bold" id="leadsValue">5 Leads</span>
                <span>50 Leads</span>
              </div>
              <p class="text-xs text-brand-sky/50 italic">Additional leads generated by your new marketing foundation.</p>
            </div>

            <div class="space-y-4 pt-4">
              <label class="block text-white font-bold text-lg mb-2">Project Investment</label>
              <div class="grid grid-cols-2 gap-4">
                <button 
                  onclick="setInvestment(998)" 
                  class="investment-btn py-3 px-4 rounded-xl border border-white/10 bg-brand-darkest text-white hover:border-brand-cyan transition-all text-xs font-bold active-investment"
                  data-value="998"
                >
                  $998 (Standard)
                </button>
                <button 
                  onclick="setInvestment(1998)" 
                  class="investment-btn py-3 px-4 rounded-xl border border-white/10 bg-brand-darkest text-white hover:border-brand-cyan transition-all text-xs font-bold"
                  data-value="1998"
                >
                  $1,998+ (Premium)
                </button>
              </div>
            </div>
          </div>

          <!-- Results Card -->
          <div class="bg-gradient-to-br from-brand-darkest to-brand-dark p-8 rounded-2xl border border-brand-cyan/20 flex flex-col items-center justify-center text-center">
            <p class="text-brand-glow text-sm font-bold uppercase tracking-widest mb-6">Yearly Projection</p>
            
            <div class="mb-8">
              <span class="text-5xl md:text-6xl font-black text-white" id="totalReturn">$90,000</span>
              <p class="text-brand-cyan text-sm font-bold mt-2" id="roiPercentage">8,918% ROI</p>
            </div>

            <div class="w-full h-px bg-white/10 mb-8"></div>

            <div class="space-y-4 w-full text-left">
              <div class="flex justify-between items-center text-xs">
                <span class="text-brand-sky/70">Potential New Revenue:</span>
                <span class="text-white font-bold" id="grossRevenue">$90,000</span>
              </div>
              <div class="flex justify-between items-center text-xs">
                <span class="text-brand-sky/70">Payback Period:</span>
                <span class="text-brand-accent font-bold" id="paybackPeriod">&lt; 1 Month</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-4xl mx-auto">
      <p class="text-brand-purple text-sm uppercase tracking-widest mb-4 text-center">✦ FAQ</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-12 text-center">
        Frequently Asked Questions
      </h2>

      <div class="space-y-4" id="pricing-faq">
        <!-- Question 1 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">What's included in the price?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Every package includes custom design, mobile responsiveness, basic SEO setup, and a contact form. Higher-tier packages add advanced functionality like booking systems, e-commerce, analytics integration, and more. All packages include web hosting setup assistance and a domain consultation.
            </div>
          </div>
        </div>

        <!-- Question 2 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">Do you offer payment plans?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Yes! We offer flexible payment plans for most packages. Typically we require 50% upfront to begin the project, with the remaining balance due upon completion. For larger projects, we can arrange monthly installments — just ask during your consultation.
            </div>
          </div>
        </div>

        <!-- Question 3 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">How long does a typical project take?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Most projects are completed within 2–4 weeks, depending on the scope. A simple 1–2 page site can be ready in as little as 1–2 weeks, while more complex builds (e-commerce, custom portals) typically take 4–6 weeks. We'll give you a clear timeline during the proposal phase.
            </div>
          </div>
        </div>

        <!-- Question 4 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">What if I need more pages than my package includes?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              No problem! Additional pages beyond the package limit are billed at a flat rate of $75–$150 per page, depending on complexity. We can also help you prioritize which pages to launch with and add more later as your business grows.
            </div>
          </div>
        </div>

        <!-- Question 5 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">Do you handle web hosting and domain setup?</span>
            <span class="faq-icon text-brand-purple text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-6 pb-6 text-white/70 text-sm leading-relaxed">
              Yes, we handle the full setup. We'll help you choose a domain, configure web hosting (or recommend the best provider for your needs), and get everything deployed. Web hosting fees are separate and typically range from $10–$30/month depending on your provider and plan.
            </div>
          </div>
        </div>

        <!-- Question 6 -->
        <div class="faq-item bg-brand-darkest border border-brand-purple/20 rounded-xl overflow-hidden transition-all duration-300">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
            <span class="text-white font-semibold pr-4">Can I upgrade my package later?</span>
