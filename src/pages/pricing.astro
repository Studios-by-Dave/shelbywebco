  <style>
    .investment-btn.active-investment {
      background-color: #22d3ee;
      color: #0a0a0a;
      border-color: #22d3ee;
      box-shadow: 0 0 15px rgba(0,255,255,0.3);
    }

    input[type='range'] {
      height: 0.5rem;
      background-color: #0a0a0a;
      border-radius: 0.5rem;
      appearance: none;
      cursor: pointer;
    }

    input[type='range']::-webkit-slider-thumb {
      width: 1.5rem;
      height: 1.5rem;
      background-color: #22d3ee;
      border-radius: 9999px;
      appearance: none;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      border: 2px solid #1a1a1a;
    }
  </style>

  <script is:inline>
    let currentInvestment = 998;

    window.setInvestment = (value) => {
      currentInvestment = value;
      
      // Update UI buttons
      document.querySelectorAll('.investment-btn').forEach(btn => {
        if (parseInt(btn.getAttribute('data-value')) === value) {
          btn.classList.add('active-investment');
        } else {
          btn.classList.remove('active-investment');
        }
      });
      
      calculateROI();
    };

    function calculateROI() {
      const avgValue = parseFloat(document.getElementById('avgValue').value) || 0;
      const leads = parseInt(document.getElementById('newLeads').value);
      
      // Update label
      document.getElementById('leadsValue').innerText = `${leads} Lead${leads > 1 ? 's' : ''}`;
      
      const yearlyLeads = leads * 12;
      const grossRevenue = yearlyLeads * avgValue;
      const netReturn = grossRevenue - currentInvestment;
      const roi = (netReturn / currentInvestment) * 100;
      const monthsToPayback = currentInvestment / (leads * avgValue);
      
      // Update DOM
      document.getElementById('totalReturn').innerText = `$${grossRevenue.toLocaleString()}`;
      document.getElementById('roiPercentage').innerText = `${roi.toLocaleString(undefined, { maximumFractionDigits: 0 })}% ROI`;
      document.getElementById('grossRevenue').innerText = `$${grossRevenue.toLocaleString()}`;
      
      const paybackEl = document.getElementById('paybackPeriod');
      if (monthsToPayback < 1) {
        paybackEl.innerText = '< 1 Month';
        paybackEl.className = 'text-brand-accent font-bold';
      } else {
        paybackEl.innerText = `${monthsToPayback.toFixed(1)} Months`;
        paybackEl.className = 'text-white font-bold';
      }
    }

    // Initialize observers
    document.addEventListener('DOMContentLoaded', () => {
      const avgInput = document.getElementById('avgValue');
      const leadsInput = document.getElementById('newLeads');
      
      if (avgInput) avgInput.addEventListener('input', calculateROI);
      if (leadsInput) leadsInput.addEventListener('input', calculateROI);

      // Initial calculation
      calculateROI();
    });
  </script>

</BaseLayout>

<script>
  // FAQ Accordion Toggle
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question') as HTMLElement | null;
      const answer = item.querySelector('.faq-answer') as HTMLElement | null;
      const icon = item.querySelector('.faq-icon') as HTMLElement | null;

      if (!question || !answer || !icon) return;

      question.addEventListener('click', () => {
        const isOpen = item.classList.contains('active');

        // Close all FAQ items
        faqItems.forEach(otherItem => {
          otherItem.classList.remove('active');
          const otherQuestion = otherItem.querySelector('.faq-question') as HTMLElement | null;
          const otherAnswer = otherItem.querySelector('.faq-answer') as HTMLElement | null;
          const otherIcon = otherItem.querySelector('.faq-icon') as HTMLElement | null;
          if (otherQuestion) otherQuestion.setAttribute('aria-expanded', 'false');
          if (otherAnswer) otherAnswer.style.maxHeight = '0';
          if (otherIcon) {
            otherIcon.textContent = '+';
            otherIcon.style.transform = 'rotate(0deg)';
          }
        });

        // If it was closed, open it
        if (!isOpen) {
          item.classList.add('active');
          question.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          icon.textContent = '−';
          icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
</script>
