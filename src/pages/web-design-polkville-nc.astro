---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Web Design Polkville, NC"
  description="Professional web design services in Polkville, NC. Custom websites, local SEO, and digital marketing for Polkville businesses. Get found online and grow your business."
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Polkville, NC</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Web Design in Polkville, NC
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Professional web design services for Polkville businesses. We build custom websites that help you stand out in the community.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Why Polkville Businesses Choose Us</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Serving Cleveland County
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">High Quality Design</h3>
          <p class="text-brand-sky/70 text-sm">We deliver beautiful, professional web design at competitive prices. Get a high-converting site that represents your business.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Local SEO</h3>
          <p class="text-brand-sky/70 text-sm">Dominate local search results. We optimize your site to appear in local queries and Google Maps across Cleveland County.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Fast Turnaround</h3>
          <p class="text-brand-sky/70 text-sm">We value your time. We deliver professional sites quickly without compromising quality so you can get back to what you do best.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Our Services</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          What We Offer Polkville Businesses
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Custom Web Design</h3>
          <p class="text-brand-sky/70 mb-4">Beautiful, responsive websites designed specifically for your Polkville business to help you stand out online.</p>
          <a href="/services/web-design" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Local SEO</h3>
          <p class="text-brand-sky/70 mb-4">Get found by local customers searching for your services. We specialize in optimizing your digital footprint so you show up first.</p>
          <a href="/services/seo" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Logo Design & Branding</h3>
          <p class="text-brand-sky/70 mb-4">Professional branding that communicates trust to your customers with bespoke logos and a complete visual identity.</p>
          <a href="/services/branding" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Digital Marketing</h3>
          <p class="text-brand-sky/70 mb-4">We act as your complete digital wingman, helping to navigate marketing solutions to grow your presence.</p>
          <a href="/contact#get-in-touch" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Grow Your Polkville Business?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's build a website that drives real results for your business. Get in touch today for a free consultation.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
