---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import polkville1 from '../../assets/service locations/polkville/Polkville nc_1.jpeg';
import polkville2 from '../../assets/service locations/polkville/Polkville nc_2.jpeg';
import polkville4 from '../../assets/service locations/polkville/polkville nc_4.jpeg';
import polkville7 from '../../assets/service locations/polkville/polkville nc_7.jpeg';
---

<BaseLayout 
  title="Web Design & Local SEO in Polkville, NC | Shelby Web Co"
  description="Elevate your Polkville business with custom web design and local SEO. We build fast, high-converting websites for small businesses in Polkville and Cleveland County."
>
  <!-- Hero Section -->
  <section class="py-24 lg:py-40 px-4 relative bg-[#0A0A0A] overflow-hidden" data-animate>
    <div class="hero-background-image absolute inset-0 z-0 opacity-40">
      <Image src={polkville2} alt="Polkville, NC Background" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0A0A]/65 via-[#0A0A0A]/70 to-[#0A0A0A] z-0"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(0,180,216,0.1),transparent_50%)] z-0"></div>
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-brand-glow/30 bg-brand-glow/5 text-brand-glow text-sm font-bold uppercase tracking-[0.2em]">
        ✦ Local Digital Partner for Polkville
      </div>
      <h1 class="font-heading text-6xl md:text-8xl font-black text-white mb-8 tracking-tight leading-[0.9]">
        Crafting Digital Growth <br /><span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-blue">For Polkville Businesses.</span>
      </h1>
      <p class="text-xl md:text-2xl text-brand-sky/80 mb-10 max-w-3xl mx-auto leading-relaxed">
        Helping Polkville's small businesses stand tall online. We build professional websites that connect you with your neighbors and grow your local presence in <span class="text-white font-bold">Cleveland County</span>.
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a 
          href="/contact#get-in-touch"
          class="group relative inline-flex items-center justify-center bg-brand-accent text-[#0A0A0A] px-10 py-4 rounded-xl font-bold text-lg hover:bg-brand-accent-light transition-all duration-300 shadow-[0_0_20px_rgba(132,204,22,0.4)] overflow-hidden"
        >
          <span class="relative z-10">Start Your Project Today</span>
          <div class="absolute inset-0 translate-x-[-100%] group-hover:translate-x-[0%] bg-white/20 transition-transform duration-300"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-24 px-4 bg-brand-darkest border-y border-white/5">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
          Is Your Polkville Business <span class="text-brand-cyan">Hard to Find Online?</span>
        </h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Tired of being invisible on Google?</span> If you don't show up when people search for services in Polkville, you're losing customers every day.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Struggling with a slow website?</span> Modern customers expect speed. A slow site kills trust and drives customers to your competitors.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Generic templates not working?</span> Your business is unique. We build custom solutions that reflect the heart of Polkville.</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <Image src={polkville1} alt="Polkville NC area landscape" class="rounded-2xl shadow-2xl aspect-square object-cover" />
        <Image src={polkville2} alt="Local business development in Polkville" class="rounded-2xl shadow-2xl aspect-square object-cover mt-8" />
      </div>
    </div>
  </section>

  <!-- Showcase / Local Advantage -->
  <section class="py-24 px-4 relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Built for Success in Polkville.</h2>
        <p class="text-brand-sky/70 max-w-2xl mx-auto text-lg">
          We understand the local market. From Polkville to Shelby and across Cleveland County, we help businesses establish a powerful digital foundation.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="relative group overflow-hidden rounded-2xl">
          <Image src={polkville4} alt="Digital marketing strategy for Polkville businesses" class="w-full h-[400px] object-cover transition-transform duration-500 group-hover:scale-110" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-8">
            <p class="text-white font-bold text-xl">Local Growth Strategies</p>
          </div>
        </div>
        <div class="relative group overflow-hidden rounded-2xl">
          <Image src={polkville7} alt="Modern web design results for local NC companies" class="w-full h-[400px] object-cover transition-transform duration-500 group-hover:scale-110" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-8">
            <p class="text-white font-bold text-xl">High-Performance Design</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5 hover:border-brand-sky/30 transition-all">
          <div class="text-brand-accent text-4xl font-black mb-2">Fast</div>
          <div class="text-white font-bold text-lg mb-2">Wait-Free Loading</div>
          <p class="text-brand-sky/60 text-sm">We optimize every image and line of code so your Polkville customers aren't left waiting.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5 hover:border-brand-sky/30 transition-all">
          <div class="text-brand-accent text-4xl font-black mb-2">Local</div>
          <div class="text-white font-bold text-lg mb-2">SEO Optimized</div>
          <p class="text-brand-sky/60 text-sm">We target local keywords that your neighbors are actually searching for in Polkville.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5 hover:border-brand-sky/30 transition-all">
          <div class="text-brand-accent text-4xl font-black mb-2">Mobile</div>
          <div class="text-white font-bold text-lg mb-2">Responsive Design</div>
          <p class="text-brand-sky/60 text-sm">Your site will look perfect on everything from a smartphone to a desktop screen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-24 px-4 bg-brand-accent/5">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-4xl md:text-6xl font-black text-white mb-8">Ready to Put Your Polkville Business <span class="text-brand-accent">on the Map?</span></h2>
      <p class="text-xl text-brand-sky/80 mb-12">
        Don't let your competitors own the local search results. Let's build a website that works as hard as you do.
      </p>
      <a 
        href="/contact"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-12 py-5 rounded-xl font-bold text-xl hover:bg-brand-accent-light transition-all duration-300 transform hover:scale-105"
      >
        Get Started Now
      </a>
    </div>
  </section>
  <style>
    .hero-background-image {
      -webkit-mask-image: linear-gradient(
        to bottom,
        black 0%,
        black 48%,
        rgba(0, 0, 0, 0.8) 68%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to bottom,
        black 0%,
        black 48%,
        rgba(0, 0, 0, 0.8) 68%,
        transparent 100%
      );
    }
  </style>

</BaseLayout>
