---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import bs1 from '../../assets/service locations/boiling springs nc/boiling springs nc_1.jpg';
import bs2 from '../../assets/service locations/boiling springs nc/boiling springs nc_2.jpg';
import bs10 from '../../assets/service locations/boiling springs nc/boiling springs nc_10.jpeg';
import bsCommunity from '../../assets/service locations/boiling springs nc/BoilingSpringLakesNC-Community.png';
---

<BaseLayout 
  title="Web Design & Local SEO in Boiling Springs, NC"
  description="Expert web design and local SEO tailored for Boiling Springs, NC businesses. We create digital platforms that connect you with the local college community and residents."
>

  <!-- Hero Section -->
  <section class="py-24 lg:py-40 px-4 relative bg-[#0A0A0A] overflow-hidden" data-animate>
    <div class="absolute inset-0 z-0 opacity-20">
      <Image src={bsCommunity} alt="Boiling Springs NC Community" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 z-0 bg-gradient-to-t from-[#0A0A0A] via-[#0A0A0A]/80 to-transparent"></div>
    <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_30%_50%,rgba(0,180,216,0.2),transparent_60%)]"></div>
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-brand-glow/30 bg-brand-glow/20 text-brand-glow text-sm font-bold uppercase tracking-[0.2em] backdrop-blur-sm">
        ✦ Local Growth for Boiling Springs, NC Businesses
      </div>
      <h1 class="font-heading text-6xl md:text-8xl font-black text-white mb-8 tracking-tight leading-[0.9]">
        Digital Foundations <br /><span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-blue">For Boiling Springs, NC.</span>
      </h1>
      <p class="text-xl md:text-2xl text-brand-sky/80 mb-10 max-w-3xl mx-auto leading-relaxed">
        Building custom websites and driving SEO campaigns that command attention right here at home. Experience <span class="text-white font-bold">real results</span> built around the Boiling Springs, NC market.
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a 
          href="/contact"
          class="group relative inline-flex items-center justify-center bg-brand-accent text-[#0A0A0A] px-10 py-4 rounded-xl font-bold text-lg hover:bg-brand-accent-light transition-all duration-300 shadow-[0_0_20px_rgba(132,204,22,0.4)] overflow-hidden"
        >
          <span class="relative z-10">Start Your Custom Strategy</span>
          <div class="absolute inset-0 translate-x-[-100%] group-hover:translate-x-[0%] bg-white/20 transition-transform duration-300"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-24 px-4 bg-brand-darkest border-y border-white/5">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
          Are Local Competitors <span class="text-brand-cyan">Stealing Your Thunder?</span>
        </h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Relying solely on word-of-mouth?</span> Expanding your customer base means having a 24/7 digital representative capturing leads when you're off the clock.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Buried in local searches?</span> The GWU community and town residents search local first. If you aren't optimized, you aren't seen.</p>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 mt-1 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
            <p class="text-brand-sky/70"><span class="text-white font-semibold">Frustrating user experience?</span> Slow, mobile-unfriendly sites actively push potential revenue straight into the hands of your competitors.</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <Image src={bs1} alt="Boiling Springs, NC business operations" class="rounded-2xl shadow-2xl aspect-square object-cover" />
        <Image src={bs10} alt="Local community engagement" class="rounded-2xl shadow-2xl aspect-square object-cover mt-8" />
      </div>
    </div>
  </section>

  <!-- The Local Advantage (Social Proof) -->
  <section class="py-24 px-4 relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Cleveland County's Hometown Choice.</h2>
        <p class="text-brand-sky/70 max-w-2xl mx-auto text-lg">
          We understand the intersection of deep-rooted local businesses and the active collegiate atmosphere that defines Boiling Springs, NC.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        <Image src={bs2} alt="Boiling Springs, NC Projects" class="rounded-xl object-cover h-64 w-full shadow-lg" />
        <Image src={bsCommunity} alt="Gardner-Webb community" class="rounded-xl object-cover h-64 w-full shadow-lg" />
        <Image src={bs1} alt="Cleveland County business growth" class="rounded-xl object-cover h-64 w-full shadow-lg" />
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-accent text-4xl font-black mb-2">100%</div>
          <div class="text-white font-bold text-lg mb-2">Performance Standards</div>
          <p class="text-brand-sky/60 text-sm">Lightning-fast speeds and flawless mobile formatting keep the college demographic engaged.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-cyan text-4xl font-black mb-2">Engaged</div>
          <div class="text-white font-bold text-lg mb-2">Community Reach</div>
          <p class="text-brand-sky/60 text-sm">We craft messaging that resonates with both long-time locals and incoming residents.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5">
          <div class="text-brand-blue text-4xl font-black mb-2">Local</div>
          <div class="text-white font-bold text-lg mb-2">Map Optimization</div>
          <p class="text-brand-sky/60 text-sm">Ensuring you appear at the top when folks nearby search for localized services.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-24 px-4 bg-brand-darkest">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="flex-1 order-2 lg:order-1">
        <div class="grid grid-cols-2 gap-4">
          <Image src={bsCommunity} alt="Web design Boiling Springs, NC" class="rounded-2xl shadow-2xl aspect-[3/4] object-cover" />
          <Image src={bs2} alt="SEO focus in Boiling Springs, NC" class="rounded-2xl shadow-2xl aspect-[3/4] object-cover mt-12" />
        </div>
      </div>
      <div class="flex-1 order-1 lg:order-2">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-8">Engineering <span class="text-brand-accent">Measurable Success.</span></h2>
        <div class="space-y-10">
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Sleek & Professional Architecture</h3>
            <p class="text-brand-sky/70 leading-relaxed">Your brand's credibility is assessed in seconds. We construct modern, visually striking platforms that communicate trust and technical competence immediately.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Hyper-Targeted SEO</h3>
            <p class="text-brand-sky/70 leading-relaxed">Rather than wasting budget on broad terms, we zero in on exactly what Boiling Springs, NC residents are searching for, driving qualified local leads directly to your inbox.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-3">Partners in Scalability</h3>
            <p class="text-brand-sky/70 leading-relaxed">Your business isn't static, and your web presence shouldn't be either. We provide the robust maintenance and continuous optimizations required to stay on top long-term.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 px-4 relative overflow-hidden bg-brand-accent/90" data-animate>
    <div class="max-w-4xl mx-auto text-center relative z-10 text-[#0A0A0A]">
      <h2 class="font-heading text-5xl md:text-6xl font-black mb-8 leading-tight">
        Claim Your Digital <br />Territory.
      </h2>
      <p class="text-xl md:text-2xl font-medium mb-10 opacity-90 text-balance">
        It’s time your Boiling Springs, NC business stepped into the spotlight. Reach out to schedule a deep-dive into your growth potential.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact"
          class="inline-block bg-[#0A0A0A] text-white px-10 py-4 rounded-xl font-black text-xl hover:scale-105 transition-all duration-300 shadow-2xl"
        >
          Book a Free Chat
        </a>
        <a 
          href="tel:+17044738188"
          class="inline-block border-2 border-[#0A0A0A] text-[#0A0A0A] px-10 py-4 rounded-xl font-black text-xl hover:bg-[#0A0A0A] hover:text-white transition-all duration-300"
        >
          (704) 473-8188
        </a>
      </div>
    </div>
  </section>

</BaseLayout>