---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Web Design Spartanburg, SC | Shelby Web Company"
  description="Professional web design services in Spartanburg, SC. Custom websites, local SEO, and digital marketing for Spartanburg businesses. Get found online and grow your business."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Spartanburg, SC</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Web Design in Spartanburg, SC
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Professional web design services for Spartanburg businesses. We build custom websites that help you succeed online.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Why Spartanburg Businesses Choose Us</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Serving Spartanburg & Upstate SC
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Cross-State Service</h3>
          <p class="text-brand-sky/70 text-sm">We proudly serve Spartanburg and the entire Upstate SC region with the same quality as our local clients.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Spartanburg SEO</h3>
          <p class="text-brand-sky/70 text-sm">Dominate local search results. We optimize your site to appear in Google Maps and local searches for Spartanburg.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Regional Expertise</h3>
          <p class="text-brand-sky/70 text-sm">We understand the Upstate SC market and what Spartanburg businesses need to compete regionally.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Our Services</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          What We Offer Spartanburg Businesses
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Custom Web Design</h3>
          <p class="text-brand-sky/70 mb-4">Beautiful, responsive websites designed specifically for your Spartanburg business. No templates, just custom design.</p>
          <a href="/services/web-design" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Local SEO</h3>
          <p class="text-brand-sky/70 mb-4">Get found by local customers searching for your services in Spartanburg. We optimize for Google Maps and local search.</p>
          <a href="/services/seo" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Logo Design & Branding</h3>
          <p class="text-brand-sky/70 mb-4">Professional branding that makes your Spartanburg business stand out. Logos, business cards, and complete brand identity.</p>
          <a href="/services/branding" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Digital Marketing</h3>
          <p class="text-brand-sky/70 mb-4">Complete digital marketing solutions to help your Spartanburg business grow online and attract more customers.</p>
          <a href="/contact#get-in-touch" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Grow Your Spartanburg Business?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's build a website that drives real results for your business. Get in touch today for a free consultation.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
