---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Web Design Gastonia, NC"
  description="Professional web design services in Gastonia, NC. Custom websites, local SEO, and digital marketing for Gastonia businesses. Get found online and grow your business."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Gastonia, NC</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Web Design in Gastonia, NC
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Professional web design services for Gastonia businesses. We build custom websites that help you succeed online.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Why Gastonia Businesses Choose Us</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Serving Gastonia Businesses
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Local Understanding</h3>
          <p class="text-brand-sky/70 text-sm">We understand the Gastonia market and what local businesses need to succeed online in this community.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Gastonia SEO</h3>
          <p class="text-brand-sky/70 text-sm">Dominate local search results. We optimize your site to appear in Google Maps and local searches for Gastonia.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Competitive Pricing</h3>
          <p class="text-brand-sky/70 text-sm">Quality web design at prices Gastonia businesses can afford. No hidden fees, transparent pricing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Our Services</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          What We Offer Gastonia Businesses
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Custom Web Design</h3>
          <p class="text-brand-sky/70 mb-4">Beautiful, responsive websites designed specifically for your Gastonia business. No templates, just custom design.</p>
          <a href="/services/web-design" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Local SEO</h3>
          <p class="text-brand-sky/70 mb-4">Get found by local customers searching for your services in Gastonia. We optimize for Google Maps and local search.</p>
          <a href="/services/seo" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Logo Design & Branding</h3>
          <p class="text-brand-sky/70 mb-4">Professional branding that makes your Gastonia business stand out. Logos, business cards, and complete brand identity.</p>
          <a href="/services/branding" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>

        <div class="bg-brand-dark border border-brand-sky/40 rounded-xl p-8">
          <h3 class="font-heading text-2xl font-bold text-white mb-4">Digital Marketing</h3>
          <p class="text-brand-sky/70 mb-4">Complete digital marketing solutions to help your Gastonia business grow online and attract more customers.</p>
          <a href="/contact#get-in-touch" class="text-brand-cyan hover:text-brand-glow transition-colors">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Grow Your Gastonia Business?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's build a website that drives real results for your business. Get in touch today for a free consultation.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
