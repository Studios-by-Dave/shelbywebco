---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact Us | Shelby Web Company"
  description="Get in touch with Shelby Web Company. Call us at (704) 473-8188 or email shelbywebco@gmail.com. Free consultations for web design, development, and digital marketing services in Shelby, NC."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Get In Touch</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Contact Us
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Ready to take your business to the next level? Let's talk about how we can help you succeed online.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <!-- Contact Info (Buttons) -->
      <div class="flex flex-col lg:flex-row items-center justify-center gap-12 mb-24">
        <div class="w-full lg:max-w-2xl space-y-6 text-center">
          <div class="text-center">
            <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Contact Information</p>
            <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">
              Reach Out Directly
            </h2>
          </div>
          
          <!-- Phone Button -->
          <a href="tel:+17044738188" class="block mx-auto w-full max-w-xl bg-brand-accent rounded-[100px] p-6 md:p-8 relative group transition-all duration-300 hover:scale-[1.02] shadow-[0_0_40px_rgba(132,204,22,0.35)]">
            <div class="flex flex-col items-center">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width={3} d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span class="text-black text-[12px] font-bold uppercase tracking-[0.2em]">Call or Text Anytime</span>
              </div>
              <div class="text-black text-3xl md:text-5xl font-black mb-3 tracking-tighter leading-none px-4">(704) 473-8188</div>
              <div class="bg-black/10 rounded-full px-5 py-1.5 text-black text-[8px] md:text-[10px] font-bold uppercase tracking-[0.15em] backdrop-blur-sm">
                Available 24/7 • Response Guaranteed
              </div>
            </div>
          </a>

          <!-- Email Button -->
          <a href="mailto:shelbywebco@gmail.com" class="block mx-auto w-full max-w-xl bg-brand-accent rounded-[100px] p-6 md:p-8 relative group transition-all duration-300 hover:scale-[1.02] shadow-[0_0_40px_rgba(132,204,22,0.35)]">
            <div class="flex flex-col items-center">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width={3} d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="text-black text-[12px] font-bold uppercase tracking-[0.2em]">Send an Email</span>
              </div>
              <div class="text-black text-lg md:text-2xl lg:text-3xl font-black mb-3 tracking-tight break-all leading-none px-4">shelbywebco@gmail.com</div>
              <div class="bg-black/10 rounded-full px-5 py-1.5 text-black text-[8px] md:text-[10px] font-bold uppercase tracking-[0.15em] backdrop-blur-sm">
                Response Guaranteed
              </div>
            </div>
          </a>
        </div>
        </div>

        <!-- Desktop Mascot -->
        <div class="hidden xl:block w-1/4 pt-12 self-center">
          <img 
            src="/optimized-mascot.png" 
            alt="Shelby Web Co Mascot" 
            class="w-full h-auto drop-shadow-[0_0_40px_rgba(132,204,22,0.25)] animate-pulse-slow rotate-3 hover:rotate-0 transition-transform duration-700"
          />
        </div>
      </div>

      <!-- Contact Form -->
      <div id="get-in-touch" class="max-w-4xl mx-auto pt-12 border-t border-white/5">
        <div class="text-center mb-12">
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Send Us a Message</p>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">
            Let's Start a Conversation
          </h2>
          <p class="text-brand-sky/60 text-lg max-w-2xl mx-auto">
            Fill out the form below and our team will get back to you within 24 hours to discuss your project in detail.
          </p>
        </div>

        <div class="bg-brand-darkest/50 backdrop-blur-xl border border-white/10 p-8 md:p-12 rounded-[40px] shadow-2xl">
          <form class="grid md:grid-cols-2 gap-8">
            <div class="space-y-6">
              <div>
                <label for="name" class="block text-brand-sky/80 text-sm font-bold uppercase tracking-wider mb-2">Your Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  class="w-full bg-black/40 border border-brand-sky/20 rounded-2xl px-6 py-4 text-white placeholder-brand-sky/20 focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all"
                  placeholder="John Doe"
                />
              </div>
              <div>
                <label for="email" class="block text-brand-sky/80 text-sm font-bold uppercase tracking-wider mb-2">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="w-full bg-black/40 border border-brand-sky/20 rounded-2xl px-6 py-4 text-white placeholder-brand-sky/20 focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all"
                  placeholder="john@example.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-brand-sky/80 text-sm font-bold uppercase tracking-wider mb-2">Phone Number</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone"
                  class="w-full bg-black/40 border border-brand-sky/20 rounded-2xl px-6 py-4 text-white placeholder-brand-sky/20 focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all"
                  placeholder="(704) 555-1234"
                />
              </div>
            </div>

            <div class="space-y-6 flex flex-col">
              <div class="flex-1">
                <label for="service" class="block text-brand-sky/80 text-sm font-bold uppercase tracking-wider mb-2">How can we help?</label>
                <select 
                  id="service" 
                  name="service"
                  class="w-full bg-black/40 border border-brand-sky/20 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-brand-accent transition-all appearance-none"
                >
                  <option value="">Select a service...</option>
                  <option value="web-design">Custom Web Design</option>
                  <option value="branding">Logo & Branding</option>
                  <option value="seo">SEO Optimization</option>
                  <option value="media">Media Packs</option>
                  <option value="audio">Audio Branding</option>
                </select>
              </div>
              <div class="flex-[2]">
                <label for="message" class="block text-brand-sky/80 text-sm font-bold uppercase tracking-wider mb-2">Project Details</label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="4" 
                  required
                  class="w-full h-full bg-black/40 border border-brand-sky/20 rounded-2xl px-6 py-4 text-white placeholder-brand-sky/20 focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all resize-none"
                  placeholder="Tell us about your goals..."
                ></textarea>
              </div>
            </div>

            <div class="md:col-span-2 pt-4">
              <button 
                type="submit"
                class="w-full bg-brand-accent text-[#0A0A0A] px-10 py-5 rounded-2xl font-black text-lg uppercase tracking-widest hover:bg-brand-accentLight hover:scale-[1.02] shadow-[0_0_30px_rgba(132,204,22,0.3)] transition-all duration-300"
              >
                Launch Conversation
              </button>
            </div>
          </form>
        </div>

        <!-- Service Area Mini Info -->
        <div class="mt-16 flex flex-col md:flex-row items-center justify-center gap-8 text-center md:text-left">
          <div class="flex items-center gap-4 bg-white/5 px-6 py-4 rounded-full border border-white/10">
            <div class="w-10 h-10 bg-brand-accent/20 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-bold text-sm uppercase tracking-wider">Service Area</p>
              <p class="text-brand-sky/60 text-sm">North Carolina & Beyond</p>
            </div>
          </div>
          <div class="flex items-center gap-4 bg-white/5 px-6 py-4 rounded-full border border-white/10">
            <div class="w-10 h-10 bg-brand-cyan/20 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-bold text-sm uppercase tracking-wider">Response Time</p>
              <p class="text-brand-sky/60 text-sm">Under 24 Hours</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
              <div>
                <p class="text-white font-medium mb-1">Service Area</p>
                <p class="text-brand-sky/70">
                  Shelby, Charlotte, Gastonia, Spartanburg, Asheville, Raleigh, and surrounding areas
                </p>
              </div>
            </div>
          </div>

          <div class="hidden lg:block w-1/3 pt-24">
            <img 
              src="/optimized-mascot.png" 
              alt="Shelby Web Co Mascot" 
              class="w-full h-auto drop-shadow-[0_0_30px_rgba(132,204,22,0.2)] animate-pulse-slow"
            />
          </div>
        </div>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="bg-brand-darkest border border-brand-sky/20 rounded-xl p-6 mb-8">
            <h3 class="font-heading text-xl font-bold text-white mb-4">Business Hours</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-brand-sky/70">Monday - Friday</span>
                <span class="text-white">9:00 AM - 6:00 PM</span>
              </div>
              <div class="flex justify-between">
                <span class="text-brand-sky/70">Saturday</span>
                <span class="text-white">10:00 AM - 4:00 PM</span>
              </div>
              <div class="flex justify-between">
                <span class="text-brand-sky/70">Sunday</span>
                <span class="text-white">Closed</span>
              </div>
            </div>
            <p class="text-brand-cyan text-sm mt-4">
              24/7 emergency support available for existing clients
            </p>
          </div>

          <!-- Social Links -->
          <div>
            <h3 class="font-heading text-xl font-bold text-white mb-4">Follow Us</h3>
            <div class="flex space-x-4">
              <a href="#" class="w-10 h-10 bg-brand-darkest border border-brand-sky/40 rounded-lg flex items-center justify-center text-brand-sky/60 hover:text-brand-glow hover:border-brand-cyan transition-all" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
              <a href="#" class="w-10 h-10 bg-brand-darkest border border-brand-sky/40 rounded-lg flex items-center justify-center text-brand-sky/60 hover:text-brand-glow hover:border-brand-cyan transition-all" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
              <a href="#" class="w-10 h-10 bg-brand-darkest border border-brand-sky/40 rounded-lg flex items-center justify-center text-brand-sky/60 hover:text-brand-glow hover:border-brand-cyan transition-all" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Prefer to Call?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Give us a ring at (704) 473-8188. We're happy to answer any questions you have about our services.
      </p>
      <a 
        href="tel:+17044738188"
        class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
      >
        Call Now
      </a>
    </div>
  </section>

</BaseLayout>
