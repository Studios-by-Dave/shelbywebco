---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import businessCard from '../../assets/about/Sweb_bcard_1.png';
---

<BaseLayout 
  title="Contact Us"
  description="Get in touch with Shelby Web Company. Call us at (704) 473-8188 or email shelbywebco@gmail.com. Free consultations for web design, development, and digital marketing services in Shelby, NC."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
        <div class="flex-1 w-full space-y-6">
          <div class="text-center mb-8">
            <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Get In Touch</p>
            <h1 class="font-heading text-6xl md:text-7xl font-bold text-white mb-6 leading-tight">
              Contact Us
            </h1>
          </div>

          <p class="text-center text-red-400 text-sm uppercase tracking-widest font-semibold mb-3">Hit the Button!</p>

          <!-- Phone Button -->
          <a 
            href="tel:+17044738188"
            class="cta-glow-shine group block max-w-xl mx-auto bg-brand-accent hover:bg-brand-accent-light p-8 rounded-[40px] transform hover:scale-[1.02]"
          >
            <div class="flex flex-col items-center text-center">
              <div class="flex items-center gap-2 mb-2 text-[#0A0A0A]/80">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span class="font-bold uppercase tracking-widest text-sm">Call or Text Anytime</span>
              </div>
              <span class="font-heading text-4xl md:text-6xl font-black text-[#0A0A0A] mb-3">(704) 473-8188</span>
              <div class="bg-black/10 px-4 py-1 rounded-full">
                <p class="text-[#0A0A0A] text-[10px] md:text-xs font-bold uppercase tracking-tighter">
                  Available 24/7 • If no immediate response 12-24 hr response guaranteed
                </p>
              </div>
            </div>
          </a>

          <!-- Email Button -->
          <a 
            href="mailto:shelbywebco@gmail.com"
            class="cta-glow-shine group block max-w-xl mx-auto bg-brand-accent hover:bg-brand-accent-light p-8 rounded-[40px] transform hover:scale-[1.02]"
          >
            <div class="flex flex-col items-center text-center">
              <div class="flex items-center gap-2 mb-2 text-[#0A0A0A]/80">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="font-bold uppercase tracking-widest text-sm">Send an Email</span>
              </div>
              <span class="font-heading text-2xl md:text-4xl font-black text-[#0A0A0A] mb-3 break-all">shelbywebco@gmail.com</span>
              <div class="bg-black/10 px-4 py-1 rounded-full">
                <p class="text-[#0A0A0A] text-[10px] md:text-xs font-bold uppercase tracking-tighter">
                  If no immediate response 12-24 hr response guaranteed
                </p>
              </div>
            </div>
          </a>
        </div>

        <!-- Right Side Image -->
        <div class="flex-1 w-full lg:max-w-md">
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-brand-accent to-brand-cyan rounded-3xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
            <div class="relative bg-brand-darkest border border-white/10 rounded-3xl overflow-hidden shadow-2xl">
              <Image 
                src={businessCard} 
                alt="Shelby Web Co Business Card" 
                class="w-full h-auto object-cover transform transition duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-darkest/80 via-transparent to-transparent opacity-60"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
    <!-- Main Contact Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="rounded-3xl border border-brand-cyan/20 bg-brand-darkest/80 p-8 mb-8 lg:mb-0">
          <p class="text-brand-sky/80 text-sm uppercase tracking-widest mb-3">Client Reviews</p>
          <div class="space-y-4">
            <div class="rounded-2xl border border-white/10 bg-brand-dark/70 p-5">
              <div class="flex items-center gap-1 mb-3">
                <span class="text-yellow-300 text-xl">★</span><span class="text-yellow-300 text-xl">★</span><span class="text-yellow-300 text-xl">★</span><span class="text-yellow-300 text-xl">★</span><span class="text-yellow-300 text-xl">★</span>
              </div>
              <p class="text-white text-lg italic mb-3">"The BEST experience!!"</p>
              <p class="text-brand-cyan/60 uppercase tracking-widest text-xs">Michelle Bryan</p>
            </div>

          </div>
          <p class="text-brand-sky/70 text-sm mt-6">Our team is ready to deliver the same high-touch service for your Shelby business.</p>
        </div>

        <!-- Secondary Info -->
        <div class="space-y-12 lg:sticky lg:top-32">
          <div class="flex items-start gap-6 group">
            <div class="w-14 h-14 bg-gradient-to-br from-brand-sky to-brand-purple rounded-2xl flex items-center justify-center shrink-0 shadow-lg group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-medium mb-1">Service Area</p>
              <p class="text-brand-sky/70">
                Shelby, Charlotte, Gastonia, Spartanburg, Asheville, Raleigh, and surrounding areas
              </p>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="bg-brand-darkest border border-brand-sky/20 rounded-xl p-6 mb-8 text-center">
            <h3 class="font-heading text-xl font-bold text-white mb-2">Business Hours</h3>
            <div class="py-2">
              <span class="text-brand-accent animate-flash-24-7 text-4xl md:text-5xl font-black uppercase tracking-tighter">Open 24/7</span>
              <p class="text-brand-sky/60 text-sm mt-1 uppercase tracking-widest">Built for the Grind</p>
            </div>
          </div>

          <!-- Social Links -->
          <div>
            <h3 class="font-heading text-xl font-bold text-white mb-4">Follow Us</h3>
            <div class="flex space-x-4">
              <a href="https://www.facebook.com/profile.php?id=61591509287089" class="w-10 h-10 bg-brand-darkest border border-brand-sky/40 rounded-lg flex items-center justify-center text-blue-500 hover:text-blue-600 hover:border-brand-cyan transition-all" aria-label="Facebook">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
              <a href="#" class="w-10 h-10 bg-brand-darkest border border-brand-sky/40 rounded-lg flex items-center justify-center text-brand-sky/60 hover:text-brand-glow hover:border-brand-cyan transition-all" aria-label="Instagram">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
              <a href="#" class="w-10 h-10 bg-brand-darkest border border-brand-sky/40 rounded-lg flex items-center justify-center text-brand-sky/60 hover:text-brand-glow hover:border-brand-cyan transition-all" aria-label="LinkedIn">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
