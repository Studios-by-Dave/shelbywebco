---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/Sweb_hero1.jpg';
import googleStars from '../../assets/badge icons/google 5 stars.png';
import comptiaBadge from '../../assets/badge icons/CompTIA_A__Digital_Badge.jpg';

import logoClaude from '../../assets/logo banner/claude-Ekx6wd5U.png';
import logoOllama from '../../assets/logo banner/ollama-logo1.png';
import logoOpencode from '../../assets/logo banner/opencode-BrfWWnj4.png';
import logoVscode from '../../assets/logo banner/vscode--vbwWAnL.jpeg';
import logoChatgpt from '../../assets/logo banner/chatgpt-logo-chat-gpt-icon-on-black-background-free-vector.jpg';
import logoDevin from '../../assets/logo banner/devin-logo-1.png';
import logoGithub from '../../assets/logo banner/github-logo-png_seeklogo-304612.png';
import logoCode from '../../assets/logo banner/code.svg';
import logoGrok from '../../assets/logo banner/grok-ai-icon.webp';
import logoLinux from '../../assets/logo banner/linux-operating-systems-logo-whatsapp-logo.jpg';
import mascotOne from '../../assets/mascot_1.jpg';

const logoMarquee = [
  { src: logoOpencode, alt: 'OpenCode Logo' },
  { src: logoClaude, alt: 'Claude Logo' },
  { src: logoVscode, alt: 'VS Code Logo' },
  { src: logoGithub, alt: 'GitHub Logo' },
  { src: logoChatgpt, alt: 'ChatGPT Logo' },
  { src: logoOllama, alt: 'Ollama Logo' },
  { src: logoDevin, alt: 'Devin Logo' },
  { src: logoCode, alt: 'Code Icon' },
  { src: logoGrok, alt: 'Grok AI Logo' },
  { src: logoLinux, alt: 'Linux/WhatsApp Logo' },
];
---

<BaseLayout 
  title="Web Design Shelby NC"
  description="Your Local Shelby, NC web design, app development & digital marketing studio. Building modern websites and custom web apps that drive real growth for local businesses. Free logo design included + $100 referral rewards."
>

  <!-- Promo Ticker/Marquee Bar -->
  <div class="bg-gradient-to-r from-gray-200 via-gray-300 to-gray-200 border-b border-gray-400 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.1),0_2px_4px_-1px_rgba(0,0,0,0.06),inset_0_1px_0_rgba(255,255,255,0.5)] overflow-hidden relative z-20 py-2">
    <div class="absolute inset-0 bg-gradient-to-b from-white/30 to-transparent pointer-events-none"></div>
    <div class="flex whitespace-nowrap animate-marquee relative z-10">
      <div class="flex items-center space-x-12 px-4">
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ Free Logo Design with any Web Package!</span>
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ $100 Unlimited Referral Bonus!</span>
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ Free SEO Audit for Local Businesses!</span>
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ Free Logo Design with any Web Package!</span>
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ $100 Unlimited Referral Bonus!</span>
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ Free SEO Audit for Local Businesses!</span>
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ Free Logo Design with any Web Package!</span>
        <span class="text-gray-900 text-xl font-heading drop-shadow-sm">✦ $100 Unlimited Referral Bonus!</span>
      </div>
    </div>
  </div>

  <style>
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      animation: marquee 30s linear infinite;
    }
  </style>

  <!-- Hero Section -->
  <section class="pt-12 pb-20 lg:pt-10 lg:pb-32 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center space-x-2 bg-brand-dark border border-brand-blue/30 rounded-full py-1.5 px-4 mb-4 shadow-[0_0_15px_rgba(29,78,216,0.1)]">
            <span class="flex h-2 w-2 rounded-full bg-brand-cyan animate-pulse"></span>
            <span class="text-white/90 text-sm font-medium tracking-wide">Trusted by 100+ Local Businesses</span>
          </div>
          <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-2 leading-tight">
            We Build More Than Just <span class="text-brand-blue">Websites</span>.
          </h1>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-white/90 mb-4 leading-tight">
            We build more than just <span class="text-brand-cyan">apps</span>.
          </h2>
          <h3 class="font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold text-brand-accent drop-shadow-[0_0_8px_rgba(132,204,22,0.5)] mb-6">
            We Build Local Business.
          </h3>
          <p class="text-lg text-white/80 mb-8 max-w-lg leading-relaxed">
            Shelby Web Company — serving Shelby, Gastonia, Forest City, Kings Mountain, Polkville, Asheville and Boiling Springs, NC.
          </p>

          <div class="flex flex-wrap gap-4 mb-8">
            <a 
              href="/contact#get-in-touch"
              class="cta-glow-shine bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light"
            >
              Get Started Today
            </a>
            <a 
              href="/about"
              class="border border-white bg-black text-white px-8 py-3 rounded-lg font-medium hover:bg-gray-900 transition-all duration-300"
            >
              Learn About Our Story
            </a>
          </div>

          <div class="space-y-3 mb-8">
            <p class="text-white/80 text-lg">• Custom websites that convert</p>
            <p class="text-white/80 text-lg">• SEO optimization</p>
            <p class="text-white/80 text-lg">• Quality digital assets</p>
          </div>

          <div class="flex items-center gap-6 mb-8">
            <Image 
              src={googleStars} 
              alt="5 Star Google Google Reviews" 
              class="h-24 md:h-32 w-auto object-contain opacity-90 hover:opacity-100 transition-opacity"
            />
            <Image 
              src={comptiaBadge} 
              alt="CompTIA A+ Certified" 
              class="h-20 md:h-28 w-auto object-contain opacity-90 hover:opacity-100 transition-opacity rounded-lg"
            />
          </div>

          <p class="text-brand-accent text-[0.85rem] sm:text-xl md:text-2xl font-bold drop-shadow-[0_0_10px_rgba(132,204,22,0.3)] animate-pulse whitespace-nowrap">
            💬 Try our live assistant chat! Click the bubble in the bottom-right.
          </p>
        </div>

        <div class="relative -mt-8 lg:-mt-24 flex flex-col items-end">
          <!-- Floating CTA -->
          <a 
            href="tel:+17044738188" 
            class="bg-brand-dark/95 backdrop-blur-md border border-brand-blue/30 rounded-2xl px-8 py-5 flex flex-col items-center justify-center hover:border-brand-cyan/50 transition-all duration-300 group shadow-2xl relative z-10 -translate-y-16 lg:-translate-y-32 lg:translate-x-6 mr-4 lg:mr-0 self-start md:self-end transform scale-100 lg:scale-105 origin-bottom-right"
          >
            <div class="flex items-center space-x-2 mb-2">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <p class="text-white text-sm font-semibold tracking-widest">CALL US TEXT US</p>
            </div>
            <p class="text-brand-accent text-4xl lg:text-5xl font-heading font-bold drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] group-hover:text-brand-cyanLight transition-colors leading-none tracking-tight py-2 animate-flash-lime">(704) 473-8188</p>
            <p class="text-white/60 text-sm">We're here 24/7</p>
          </a>
          
          <div class="relative w-full">
            <!-- Subtle Wood Grain Border -->
            <div 
              class="relative z-10 p-[3px] rounded-2xl shadow-2xl bg-[#614532]/40"
              style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22wood%22%3E%3CfeTurbulence type=%22fractalSum%22 baseFrequency=%220.01 0.1%22 numOctaves=%223%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23wood)%22 opacity=%220.25%22 blend-mode=%22overlay%22/%3E%3C/svg%3E');"
            >
              <Image 
                src={heroImage} 
                alt="Professional web design and local SEO services in Shelby, NC - Shelby Web Company" 
                class="rounded-[13px] w-full"
                width={800}
                height={600}
                loading="eager"
              />
            </div>
            <div class="absolute -inset-4 bg-gradient-to-r from-brand-blue/20 to-brand-cyan/20 rounded-2xl blur-xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech/Partner Logo Marquee Strip -->
  <section class="py-12 border-y border-brand-blue/20 bg-white overflow-hidden" data-animate>
    <div class="max-w-7xl mx-auto px-4">
      <p class="text-center text-brand-dark font-bold text-sm uppercase tracking-widest mb-8">
        Powered by the best in the industry
      </p>
      <div class="relative flex" style="width: 200%;">
        <div class="animate-marquee flex gap-16 sm:gap-24 items-center justify-center w-1/2">
          {logoMarquee.map((logo) => (
            <div class="flex items-center justify-center min-w-[8rem] max-w-[12rem] px-4">
              <Image src={logo.src} alt={logo.alt} class="max-h-28 sm:max-h-40 w-auto max-w-full object-contain mix-blend-multiply filter grayscale opacity-80 contrast-125" />
            </div>
          ))}
        </div>
        
        <div class="animate-marquee flex gap-16 sm:gap-24 items-center justify-center w-1/2" aria-hidden="true">
          {logoMarquee.map((logo) => (
            <div class="flex items-center justify-center min-w-[8rem] max-w-[12rem] px-4">
              <Image src={logo.src} alt={logo.alt} class="max-h-28 sm:max-h-40 w-auto max-w-full object-contain mix-blend-multiply filter grayscale opacity-80 contrast-125" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-brand-blue text-sm uppercase tracking-widest mb-4">✦ Professional Web Design Keeping You In Mind</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Everything Your Business Needs
        </h2>
        <p class="text-lg text-white/80 max-w-3xl">
          We're your local specialized web development and marketing toolkit. Our tailored approach to your business needs ensures maximum ROI for your industry. At Shelby Web Company, our focus is <span class="text-brand-cyan">YOU</span>!
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Web Design Card -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-6 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-blue to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Web Design</h3>
            <p class="text-base text-white/70 mb-4">Custom, responsive websites that convert visitors into customers. Optimized for local businesses and service businesses.</p>
            <ul class="space-y-2 text-base text-white/70 mb-4">
              <li>• Mobile-First Design</li>
              <li>• Lightning Fast Loading</li>
              <li>• Lead Generation Forms</li>
              <li>• Local SEO Built-In</li>
            </ul>
            <a href="/services/web-design" class="text-brand-cyan hover:text-brand-cyanLight text-base font-medium transition-colors">
              Learn About Web Design →
            </a>
          </div>
        </div>

        <!-- Branding Card -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-6 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-blue to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Logo Design & Branding</h3>
            <p class="text-base text-white/70 mb-4">Professional branding packages that make your business stand out from competitors and build trust with customers.</p>
            <ul class="space-y-2 text-base text-white/70 mb-4">
              <li>• Custom Logo Design</li>
              <li>• Brand Identity Package</li>
              <li>• Business Card Design</li>
              <li>• Social Media Assets</li>
            </ul>
            <a href="/services/branding" class="text-brand-cyan hover:text-brand-cyanLight text-base font-medium transition-colors">
              Learn About Branding →
            </a>
          </div>
        </div>

        <!-- SEO Card -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-6 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-blue to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">SEO Services</h3>
            <p class="text-base text-white/70 mb-4">Complete search engine optimization to help your business dominate search results and attract more customers.</p>
            <ul class="space-y-2 text-base text-white/70 mb-4">
              <li>• Technical SEO</li>
              <li>• On-Page Optimization</li>
              <li>• Local Search Dominance</li>
              <li>• Google Business Profile</li>
            </ul>
            <a href="/services/seo" class="text-brand-cyan hover:text-brand-cyanLight text-base font-medium transition-colors">
              Learn About SEO Services →
            </a>
          </div>
        </div>

        <!-- Media Packs Card -->
        <div class="group bg-gradient-to-br from-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-6 hover:border-brand-cyan/50 hover:shadow-[0_20px_40px_rgba(34,211,238,0.15)] hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-cyan/5 blur-[80px] group-hover:bg-brand-cyan/20 transition-all duration-500"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-brand-blue to-brand-cyan rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">Custom Media Packs</h3>
            <p class="text-base text-white/70 mb-4">Custom Digital Content — Ready to Use, Ready to Convert. Get high-quality visuals tailored to your business.</p>
            <ul class="space-y-2 text-base text-white/70 mb-4">
              <li>• Custom Visuals & Graphics</li>
              <li>• Website & Social Ready</li>
              <li>• Fast Turnaround Delivery</li>
              <li>• Conversion-Focused Design</li>
            </ul>
            <a href="/services/media-packs" class="text-brand-cyan hover:text-brand-cyanLight text-base font-medium transition-colors">
              Learn About Media Packs →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <p class="text-brand-blue text-sm uppercase tracking-widest mb-4">✦ Specialized for Your Industry</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-12">
        We Understand Your Business
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Roofer Icon -->
        <div class="bg-brand-darkest border border-brand-blue/20 rounded-xl p-6 hover:border-brand-cyan/50 transition-colors group">
          <div class="w-12 h-12 bg-amber-500/10 rounded-lg flex items-center justify-center mb-4 text-amber-500 group-hover:bg-amber-500/20 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-white mb-2">Roofers & External Trades</h3>
          <p class="text-base text-white/70">Lead generation systems that convert homeowners.</p>
        </div>

        <!-- Landscaping Icon -->
        <div class="bg-brand-darkest border border-brand-blue/20 rounded-xl p-6 hover:border-brand-cyan/50 transition-colors group">
          <div class="w-12 h-12 bg-emerald-500/10 rounded-lg flex items-center justify-center mb-4 text-emerald-500 group-hover:bg-emerald-500/20 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8a7 7 0 0 1-7 7"/><path d="M7 21c-4.3-1.47-6-6.44-6-10a5.1 5.1 0 0 1 5.1-4c2.8 0 5.1 2 5.1 5.9a13.3 13.3 0 0 1-4.2 8.1Z"/></svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-white mb-2">Landscaping Companies</h3>
          <p class="text-base text-white/70">Seasonal promotions and project portfolios.</p>
        </div>

        <!-- Solar Icon -->
        <div class="bg-brand-darkest border border-brand-blue/20 rounded-xl p-6 hover:border-brand-cyan/50 transition-colors group">
          <div class="w-12 h-12 bg-blue-500/10 rounded-lg flex items-center justify-center mb-4 text-blue-500 group-hover:bg-blue-500/20 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-white mb-2">Solar Panel Installers</h3>
          <p class="text-base text-white/70">ROI calculators and educational content.</p>
        </div>

        <!-- Tree Specialists Icon -->
        <div class="bg-brand-darkest border border-brand-blue/20 rounded-xl p-6 hover:border-brand-cyan/50 transition-colors group">
          <div class="w-12 h-12 bg-green-500/10 rounded-lg flex items-center justify-center mb-4 text-green-500 group-hover:bg-green-500/20 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M17 20h.01"/><path d="M12 20h.01"/><path d="M7 20h.01"/><path d="M18 9.5a5 5 0 0 0-8-4.09A5 5 0 0 0 2 9.5a5 5 0 0 0 2 4l3 3h10l3-3a5 5 0 0 0 0-7Z"/><path d="M12 13V5"/></svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-white mb-2">Tree Specialists</h3>
          <p class="text-base text-white/70">Emergency services and seasonal care programs.</p>
        </div>

        <!-- Trucking Icon -->
        <div class="bg-brand-darkest border border-brand-blue/20 rounded-xl p-6 hover:border-brand-cyan/50 transition-colors group">
          <div class="w-12 h-12 bg-yellow-400/10 rounded-lg flex items-center justify-center mb-4 text-yellow-400 group-hover:bg-yellow-400/20 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-5h-7v6h2"/><path d="M21 13h-4"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-white mb-2">Expedited Trucking</h3>
