---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixieDust from '../../components/PixieDust.jsx';
import { Image } from 'astro:assets';

import comptiaBadge from '../../../assets/badge icons/CompTIA_A__Digital_Badge.jpg';
import projectBadge from '../../../assets/badge icons/badge_2.jpeg';
import sbdChart from '../../../assets/sbd ide chart1.png';
---

<BaseLayout 
  title="Professional Web Design Services | Shelby Web Co"
  description="High-performance, conversion-focused web design services. We build fast, mobile-responsive websites with built-in SEO to help your business grow."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Web Design & Development</p>
      <div class="relative inline-block">
        <PixieDust client:load />
        <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
          Professional <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blue-light to-brand-sky">Web Design</span> with You in Mind
        </h1>
      </div>
      <p class="text-xl text-brand-sky/80 mb-8">
        We build responsive, high-performance websites that turn visitors into customers. Optimized for your specific business needs and built for long-term growth.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="/contact#get-in-touch"
          class="cta-glow-shine inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light"
        >
          Get Your Free Quote
        </a>
        <a 
          href="tel:+17044738188"
          class="text-white text-xl md:text-2xl font-bold hover:text-brand-accent transition-colors"
        >
          (704) 473-8188
        </a>
      </div>
      
      <div class="mt-12 flex justify-center items-center gap-8">
        <Image 
          src={comptiaBadge} 
          alt="CompTIA A+ Digital Badge" 
          class="h-24 md:h-28 w-auto object-contain opacity-90 hover:opacity-100 transition-opacity"
        />
        <Image 
          src={projectBadge} 
          alt="Quality Project Badge" 
          class="h-24 md:h-28 w-auto object-contain opacity-90 hover:opacity-100 transition-opacity"
        />
      </div>
    </div>
  </section>

  <!-- Key Features Section -->
  <section class="py-24 px-4 bg-brand-darkest border-y border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Built for Performance, Designed for Growth</h2>
        <p class="text-brand-sky/70 max-w-2xl mx-auto text-lg">
          We combine modern web design, technical SEO fundamentals, and conversion strategy so your site performs for both users and search engines.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5 hover:border-brand-cyan/30 transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-amber-500 via-amber-400 to-yellow-400 rounded-lg flex items-center justify-center mb-6 text-white shadow-sm shadow-amber-500/20">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Lightning Fast Performance</h3>
          <p class="text-brand-sky/60">Speed is a ranking factor. Our sites are optimized for core web vitals and rapid load times on all devices.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5 hover:border-brand-cyan/30 transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-amber-500 via-amber-400 to-yellow-400 rounded-lg flex items-center justify-center mb-6 text-white shadow-sm shadow-amber-500/20">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Mobile-First Response</h3>
          <p class="text-brand-sky/60">With over 60% of traffic coming from mobile, we ensure your site looks and works perfectly on every screen size.</p>
        </div>
        <div class="bg-brand-dark p-8 rounded-2xl border border-white/5 hover:border-brand-cyan/30 transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-amber-500 via-amber-400 to-yellow-400 rounded-lg flex items-center justify-center mb-6 text-white shadow-sm shadow-amber-500/20">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">SEO Built-In</h3>
          <p class="text-brand-sky/60">We don't treat SEO as an afterthought. Clean code and proper structure are baked into every site we build.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Indexing Section -->
  <section class="py-24 px-4 bg-[#f8f9fc] text-slate-900 relative overflow-hidden" style="background-image: linear-gradient(rgba(148,163,184,0.18) 1px, transparent 1px); background-size: 100% 1.75rem;">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-brand-blue text-sm uppercase tracking-widest mb-4">✦ Technical Architecture</p>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-slate-900 mb-8 leading-tight">
            Beautiful Design is Only Half the Battle. <span class="text-brand-blue">Google Needs to Read It.</span>
          </h2>
          <div class="space-y-6 text-slate-700 text-lg">
            <p>
              Nowadays, many <span class="text-slate-900 font-semibold">AI website builders</span> can create a site that looks stunning in minutes. But here's the catch: many of them deliver an "empty shell" to search engines.
            </p>
            <p>
              Your pages might look great in a browser, but they often <span class="text-red-500 font-bold underline">magically don't show up on Google.</span> This happens because the content is locked behind un-rendered code that search engine crawlers simply skip.
            </p>
            <p>
              At Shelby Web Co, our <span class="text-slate-900">core coding framework</span> is built from the ground up to ensure every URL and page is properly indexed. We use advanced <span class="text-brand-cyan">pre-rendering options</span> to convert your site into content-rich HTML that Google reads instantly.
            </p>
          </div>
          
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <div class="flex items-center gap-3 bg-white shadow-sm border border-slate-200 px-6 py-4 rounded-2xl">
              <div class="w-10 h-10 bg-brand-blue/10 rounded-full flex items-center justify-center text-brand-blue">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <div>
                <p class="text-slate-900 font-bold">Instantly Indexable</p>
                <p class="text-slate-500 text-sm">Every page ready for Googlebots</p>
              </div>
            </div>
            <div class="flex items-center gap-3 bg-white shadow-sm border border-slate-200 px-6 py-4 rounded-2xl">
              <div class="w-10 h-10 bg-brand-blue/10 rounded-full flex items-center justify-center text-brand-blue">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
              <div>
                <p class="text-slate-900 font-bold">Zero "Empty Shells"</p>
                <p class="text-slate-500 text-sm">No JavaScript-only content blocks</p>
              </div>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 bg-brand-blue/10 blur-3xl rounded-full"></div>
          <div class="relative bg-white p-8 rounded-3xl border border-slate-200 shadow-2xl">
            <div class="flex items-center gap-2 mb-6 border-b border-slate-200 pb-4">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <p class="text-slate-500 text-xs ml-2 font-mono">search-index-status.log</p>
            </div>
            <div class="space-y-4 font-mono text-sm text-slate-700">
              <div class="flex gap-4">
                <span class="text-slate-400">01</span>
                <span class="text-slate-700">Crawling</span>
                <span class="text-slate-900">yourbusiness.com/services...</span>
              </div>
              <div class="flex gap-4">
                <span class="text-brand-cyan">Success:</span>
                <span class="text-slate-600">Full HTML content detected.</span>
              </div>
              <div class="flex gap-4">
                <span class="text-brand-cyan">Success:</span>
                <span class="text-slate-600">Titles & Metadata resolved.</span>
              </div>
              <div class="flex gap-4">
                <span class="text-slate-400">04</span>
                <span class="text-slate-700">Indexing</span>
                <span class="text-slate-900">Page live on Google Search.</span>
              </div>
              <div class="mt-8 pt-4 border-t border-slate-200 flex items-center gap-4">
                <div class="px-3 py-1 bg-brand-blue/10 text-brand-blue text-[10px] font-bold rounded uppercase">SEO Optimized Build</div>
                <div class="text-xs text-slate-500 italic">Shelby Web Co Static Pipeline v2.4</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-24 px-4" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-purple text-sm uppercase tracking-widest mb-4">✦ Transparent Pricing</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Investment Options</h2>
        <p class="text-xl text-white/80 max-w-3xl mx-auto">
          Clear price ranges for every project. No hidden fees, no surprises — just honest pricing that scales with your needs.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Starter Package -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Starter Website</h3>
          <p class="text-white/60 text-sm mb-6 italic">Simple brochure sites</p>
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-brand-accent text-sm font-bold uppercase tracking-wider mb-1 animate-pulse">Now ONLY</span>
              <span class="text-4xl md:text-5xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$598</span>
            </div>
          </div>
          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 1-2 page brochure site</li>
            <li>• Mobile-responsive design</li>
            <li>• Contact form included</li>
            <li>• Basic SEO setup</li>
            <li>• 1 revision round</li>
          </ul>
          <a href="/contact#get-in-touch" class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center">Get Started</a>
        </div>

        <!-- Business Package -->
        <div class="bg-gradient-to-br from-[#111111] via-brand-darkest to-brand-dark border border-[#f3db70]/50 rounded-2xl p-8 shadow-[inset_0_2px_2px_rgba(255,255,255,0.15),_0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[inset_0_2px_2px_rgba(255,255,255,0.2),_0_25px_50px_rgba(0,0,0,0.7),_0_0_40px_rgba(243,219,112,0.25)] transition-all duration-300 relative z-10 scale-100 lg:scale-105">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#f3db70] text-[#0A0A0A] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider drop-shadow-md">Most Popular</div>
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Business Web Package</h3>
          <p class="text-white/60 text-sm mb-6 italic">Standard business sites</p>
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$998 - $1,998</span>
            </div>
          </div>
          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 3-5 page business site</li>
            <li>• Custom design & branding</li>
            <li>• Advanced contact forms</li>
            <li>• Local SEO optimization</li>
            <li>• 2 revision rounds</li>
            <li>• Analytics integration</li>
          </ul>
          <a href="/contact#get-in-touch" class="block w-full bg-brand-accent text-[#0A0A0A] px-6 py-3 rounded-lg font-medium hover:bg-brand-accent-light transition-all duration-300 text-center shadow-[0_0_15px_rgba(132,204,22,0.3)]">Get Started</a>
        </div>

        <!-- Scale Package -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Scale Web Package</h3>
          <p class="text-white/60 text-sm mb-6 italic">Multi-service or locations</p>
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$2,000 - $3,998</span>
            </div>
          </div>
          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 6-10 page site</li>
            <li>• Advanced functionality</li>
            <li>• Booking/appointment system</li>
            <li>• E-commerce ready</li>
            <li>• Custom integrations</li>
            <li>• 3 revision rounds</li>
            <li>• Priority support</li>
          </ul>
          <a href="/contact#get-in-touch" class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center">Get Started</a>
        </div>

        <!-- Enterprise Package -->
        <div class="bg-gradient-to-br from-[#151515] via-brand-dark to-brand-darkest border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Enterprise</h3>
          <p class="text-white/60 text-sm mb-6 italic">Complex custom solutions</p>
          <div class="mb-6">
            <div class="text-center min-h-[4rem] flex items-center justify-center">
              <span class="text-2xl md:text-3xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">Contact For Quote</span>
            </div>
          </div>
          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• 10+ pages</li>
            <li>• Custom web applications</li>
            <li>• Membership portals</li>
            <li>• Advanced CRM integrations</li>
            <li>• Custom API development</li>
            <li>• Unlimited revisions</li>
            <li>• Dedicated account manager</li>
          </ul>
          <a href="/contact#get-in-touch" class="block w-full border-2 border-brand-purple text-brand-purple px-6 py-3 rounded-lg font-medium hover:bg-brand-purple hover:text-white transition-all duration-300 text-center">Book Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Monthly Website Care Plans Section -->
  <section class="py-20 px-4 bg-brand-darkest/30" data-animate>
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Monthly Website Care Plans</h2>
        <p class="text-xl text-brand-sky/80 max-w-2xl mx-auto">
          Keep your investment secure, fast, and running smoothly with our ongoing maintenance and support plans.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        
        <!-- Standard Plan -->
        <div class="bg-gradient-to-br from-brand-dark via-brand-darkest to-[#050505] border border-white/10 rounded-2xl p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.5)] hover:shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),_0_25px_50px_rgba(0,0,0,0.6),_0_0_30px_rgba(132,204,22,0.15)] transition-all duration-300 relative z-0">
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Website Care Plan - Standard</h3>
          <p class="text-white/60 text-sm mb-6 italic">Secure web hosting & maintenance</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-4xl md:text-5xl font-black font-nav text-[#f3db70] drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] whitespace-nowrap">$75<span class="text-lg text-white/60 font-normal">/mo</span></span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• Premium Web Hosting</li>
            <li>• Backups & Core Updates</li>
            <li>• Image & Text Revisions</li>
            <li>• 24/7 Security Scanning</li>
            <li>• Performance Optimization</li>
            <li>• Uptime Monitoring</li>
            <li>• Email Support</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="block w-full bg-brand-green text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300 text-center"
          >
            Select Standard Plan
          </a>
        </div>

        <!-- Premium Plan -->
        <div class="bg-gradient-to-br from-[#111111] via-brand-darkest to-brand-dark border border-[#f3db70]/50 rounded-2xl p-8 shadow-[inset_0_2px_2px_rgba(255,255,255,0.15),_0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[inset_0_2px_2px_rgba(255,255,255,0.2),_0_25px_50px_rgba(0,0,0,0.7),_0_0_40px_rgba(243,219,112,0.25)] transition-all duration-300 relative z-10 scale-100 lg:scale-105">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[linear-gradient(110deg,#f3db70,45%,#fff,55%,#9b7b2a)] bg-[length:200%_auto] animate-shine text-[#0A0A0A] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider drop-shadow-md">
            Recommended
          </div>
          <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Premium Website Care Plan</h3>
          <p class="text-white/60 text-sm mb-6 italic">Everything for tip-top performance</p>
          
          <div class="mb-6">
            <div class="flex flex-col items-center justify-center">
              <span class="text-4xl md:text-5xl font-black font-nav bg-[linear-gradient(110deg,#f3db70,45%,#fff,55%,#9b7b2a)] bg-[length:200%_auto] animate-shine bg-clip-text text-transparent drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] whitespace-nowrap">$149<span class="text-lg text-white/60 font-normal">/mo</span></span>
            </div>
          </div>

          <ul class="space-y-3 text-sm text-white/70 mb-8">
            <li>• Premium Web Hosting</li>
            <li>• Daily Backups & Core Updates</li>
            <li>• **Unlimited Image/Text Revisions**</li>
            <li>• Advanced Malware Protection</li>
            <li>• Performance & SEO Monitoring</li>
            <li>• Priority Support</li>
            <li>• <strong>1 Hour of Code Development/mo</strong></li>
            <li>• Detailed Monthly Reports</li>
          </ul>

          <a 
            href="/contact#get-in-touch" 
            class="cta-glow-shine block w-full bg-brand-accent text-[#0A0A0A] px-6 py-3 rounded-lg font-medium hover:bg-brand-accent-light text-center"
          >
            Select Premium Plan
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <!-- Service Area Mentions for SEO -->
  <section class="py-12 px-4 border-t border-white/5 bg-brand-darkest/50">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-sm text-brand-sky/40">
        <span class="text-brand-glow/60 uppercase tracking-widest font-bold">Serving Our Community:</span>
        <a href="/web-design-shelby-nc" class="hover:text-brand-cyan transition-colors">Shelby Web Design</a>
        <a href="/web-design-gastonia-nc" class="hover:text-brand-cyan transition-colors">Gastonia SEO</a>
        <a href="/web-design-asheville-nc" class="hover:text-brand-cyan transition-colors">Asheville Web Dev</a>
        <a href="/web-design-forest-city-nc" class="hover:text-brand-cyan transition-colors">Forest City Marketing</a>
        <a href="/web-design-boiling-springs-nc" class="hover:text-brand-cyan transition-colors">Boiling Springs Design</a>
        <a href="/web-design-kings-mountain-nc" class="hover:text-brand-cyan transition-colors">Kings Mountain Web Design</a>
      </div>
    </div>
  </section>

  <!-- Review Section -->
  <section class="py-20 px-4" data-animate>
    <div class="max-w-4xl mx-auto">
