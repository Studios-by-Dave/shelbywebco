---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixieDust from '../../components/PixieDust.jsx';
---

<BaseLayout 
  title="Web Design | Shelby Web Company"
  description="Professional web design and development services in Shelby, NC. Custom, responsive websites that convert visitors into customers. Mobile-first design, fast loading, and local SEO built-in."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Web Design</p>
      <div class="relative inline-block">
        <PixieDust client:load />
        <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
          Professional Web Design with You in Mind
        </h1>
      </div>
      <p class="text-xl text-brand-sky/80 mb-8">
        We build responsive, high-performance websites that turn visitors into customers. Optimized for local contractors and service businesses.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ What We Offer</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Professional Web Design Features
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Mobile-First Design</h3>
          <p class="text-brand-sky/70 text-sm">Your website looks great on any device – phones, tablets, and desktops. We prioritize mobile experience for maximum reach.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Lightning Fast Loading</h3>
          <p class="text-brand-sky/70 text-sm">Speed matters. We optimize every element to ensure your site loads quickly, improving user experience and SEO rankings.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Lead Generation Forms</h3>
          <p class="text-brand-sky/70 text-sm">Capture more leads with strategically placed contact forms and calls-to-action that convert visitors into customers.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Local SEO Built-In</h3>
          <p class="text-brand-sky/70 text-sm">Get found by local customers. We optimize your site for local search so you appear in Google Maps and local search results.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Custom Design</h3>
          <p class="text-brand-sky/70 text-sm">No templates here. Every website is custom-designed to reflect your brand and meet your specific business needs.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Secure & Reliable</h3>
          <p class="text-brand-sky/70 text-sm">SSL certificates, secure hosting, and regular backups keep your website safe and your data protected.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Build Your Online Engine?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's create a website that drives real business growth. Get in touch today for a free consultation.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accentLight shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
