---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Portfolio | Shelby Web Company"
  description="View our portfolio of web design, branding, and digital marketing projects. See our work for local businesses in Shelby, Charlotte, and surrounding areas."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Portfolio</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Our Work
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Browse our portfolio of websites, branding projects, and digital marketing campaigns for local businesses.
      </p>
    </div>
  </section>

  <!-- Coming Soon Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-12">
        <svg class="w-16 h-16 text-brand-cyan mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <h2 class="font-heading text-3xl font-bold text-white mb-4">
          Portfolio Coming Soon
        </h2>
        <p class="text-brand-sky/80 mb-8">
          We're currently building our portfolio gallery. Check back soon to see examples of our web design, branding, and digital marketing work.
        </p>
        <a 
          href="/contact#get-in-touch"
          class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
        >
          Start Your Project
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Want Your Project Featured?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's create something amazing together. Get in touch today to discuss your project.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
