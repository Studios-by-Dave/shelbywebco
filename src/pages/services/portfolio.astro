---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import swebscreen from '../../../assets/portfolio/swebscreen_1.png';
import swebHero from '../../../assets/Sweb_hero1.jpg';
import studiosByDave from '../../../assets/portfolio/studiosbydave.webp';
import fsExpedited from '../../../assets/portfolio/fs-expedited.jpg';
import padgsteenGuitars from '../../../assets/portfolio/padgsteenguitars.png';
import shadesOfGray from '../../../assets/portfolio/shades-of-gray.png';
import leeConstruction from '../../../assets/portfolio/lee-construction.png';
import odysseyRenovations from '../../../assets/portfolio/odyssey-renovations.png';
import bigFuturisticPictureBox from '../../../assets/portfolio/big-futuristic-picture-box.png';
import audioNotesAi from '../../../assets/portfolio/audio-notes-ai.png';
import musicalLock from '../../../assets/portfolio/musical-lock.png';
import mikesGutHealer from '../../../assets/portfolio/mikes-gut-healer.png';
import theLivingWord from '../../../assets/portfolio/the-living-word.png';
import rifeGenerator from '../../../assets/portfolio/rife-generator.png';
import gAnalyzer from '../../../assets/portfolio/5g-analyzer.png';
---

<BaseLayout 
  title="Portfolio | Shelby Web Co"
  description="View our portfolio of web design, branding, and digital marketing projects. See our work for local businesses in Shelby, Charlotte, and surrounding areas."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Portfolio</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Our Work
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Browse our portfolio of websites, branding projects, and digital marketing campaigns for local businesses.
      </p>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="py-20 px-4 bg-brand-darkest" data-animate>
    <div class="max-w-7xl mx-auto">
      
      <!-- Websites Section -->
      <div class="mb-24">
        <div class="mb-12">
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Websites</p>
          <h2 class="font-heading text-4xl font-bold text-white mb-6">Websites</h2>
          <p class="text-brand-sky/70 text-lg max-w-3xl">Professional, responsive websites built for local businesses. From service providers to artisans, we create digital experiences that convert visitors into customers.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Shelby Web Company -->
          <div class="group bg-brand-dark border border-brand-accent/50 rounded-2xl overflow-hidden hover:border-brand-accent transition-all duration-300 shadow-xl shadow-brand-accent/5">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={swebscreen} alt="Shelby Web Company Homepage" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
               <div class="absolute inset-0 bg-gradient-to-t from-brand-darkest/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                 <span class="text-brand-accent font-bold text-sm">Latest Project</span>
               </div>
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-1">Shelby Web Company</h3>
              <p class="text-brand-glow text-xs uppercase tracking-widest mb-3">(formerly Studios by Dave)</p>
              <p class="text-brand-sky/70 text-sm mb-4">High-performance digital presence built for Cleveland County businesses, featuring local SEO strategy and conversion-focused design.</p>
            </div>
          </div>

          <!-- Former Branding (Studios by Dave) -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={studiosByDave} alt="Studios by Dave Homepage" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-1">Studios by Dave (Legacy)</h3>
              <p class="text-brand-glow text-xs uppercase tracking-widest mb-3">(now Shelby Web Company)</p>
              <p class="text-brand-sky/70 text-sm mb-4">Our former flagship website which has now evolved into Shelby Web Company, continuing our mission of digital excellence.</p>
            </div>
          </div>

          <!-- F&S Expedited LLC -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={fsExpedited} alt="F&S Expedited LLC Homepage" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">F&S Expedited LLC</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Professional interstate freight carrier specializing in reliable, fast, and customer-focused logistics solutions from Shelby, NC.</p>
            </div>
          </div>

          <!-- Padgsteen Guitars -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={padgsteenGuitars} alt="Padgsteen Guitars Homepage" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Padgsteen Guitars</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Handcrafted guitars & soulful Southern music from the heart of Appalachia. A beautiful showcase for a master luthier and musician.</p>
            </div>
          </div>

          <!-- Shades of Gray Painters -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={shadesOfGray} alt="Shades of Gray Painters Homepage" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Shades of Gray Painters</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Professional painting company website featuring interior, exterior, and specialty finishes with a texture gallery showcase.</p>
            </div>
          </div>

          <!-- Lee Construction -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={leeConstruction} alt="Lee Construction Homepage" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Lee Construction</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Shelby's trusted building expert since 1982. Commercial developments to custom homes with quality craftsmanship.</p>
            </div>
          </div>

          <!-- Odyssey Custom Renovations -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={odysseyRenovations} alt="Odyssey Custom Renovations Homepage" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Odyssey Custom Renovations</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Home renovation specialists transforming kitchens, bathrooms, and complete home makeovers with expert craftsmanship.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Web Applications Section -->
      <div>
        <div class="mb-12">
          <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Web Applications</p>
          <h2 class="font-heading text-4xl font-bold text-white mb-6">Web Applications</h2>
          <p class="text-brand-sky/70 text-lg max-w-3xl">Interactive web applications showcasing our technical expertise. From specialized tools to innovative solutions.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Big Futuristic Picture Box -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-purple/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={bigFuturisticPictureBox} alt="Big Futuristic Picture Box Application" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Big Futuristic Picture Box</h3>
              <p class="text-brand-sky/70 text-sm mb-4">AI-powered multi-layered image generator with advanced image reference and image doctor capabilities for creative professionals.</p>
            </div>
          </div>

          <!-- Audio Notes AI -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-purple/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={audioNotesAi} alt="Audio Notes AI Application" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Audio Notes AI</h3>
              <p class="text-brand-sky/70 text-sm mb-4">AI-powered audio notes transcriber that transforms your audio notes and snippets into visual data, graphs, and actionable plans.</p>
            </div>
          </div>

          <!-- Musical Lock -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-purple/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={musicalLock} alt="Musical Lock Application" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Musical Lock</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Revolutionary authentication system replacing passwords with memorable melodies for secure access.</p>
            </div>
          </div>

          <!-- Mikes Gut Healer 5000 -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-purple/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={mikesGutHealer} alt="Mikes Gut Healer 5000 Application" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">Mikes Gut Healer 5000</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Fully comprehensive resource for gut healing, featuring earth medicines and Rife frequencies for true body, mind, and spirit healing.</p>
            </div>
          </div>

          <!-- The Living Word -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-purple/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={theLivingWord} alt="The Living Word Application" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">The Living Word</h3>
              <p class="text-brand-sky/70 text-sm mb-4">KJV-powered tool of spiritual life guidance with AI training based strictly on the King James Version of the Holy Bible.</p>
            </div>
          </div>

          <!-- RIFE Frequency Generator -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-purple/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={rifeGenerator} alt="RIFE Frequency Generator Application" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">RIFE Frequency Generator</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Professional 20 MHz sweep/function generator with audio samples and frequency generation capabilities.</p>
            </div>
          </div>

          <!-- 5G Spectrum Analyzer -->
          <div class="group bg-brand-dark border border-white/10 rounded-2xl overflow-hidden hover:border-brand-purple/50 transition-all duration-300 shadow-xl">
            <div class="aspect-video bg-brand-darkest relative overflow-hidden">
               <Image src={gAnalyzer} alt="5G Spectrum Analyzer Application" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-2xl font-bold text-white mb-3">5G Spectrum Analyzer</h3>
              <p class="text-brand-sky/70 text-sm mb-4">Professional RF spectrum analysis system for passive monitoring across multiple frequency bands.</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Want Your Project Featured?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's create something amazing together. Get in touch today to discuss your project.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
