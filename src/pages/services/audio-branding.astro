---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Audio Branding"
  description="Professional audio branding services in Shelby, NC. Custom sound design, voiceovers, and audio identity that makes your brand memorable. Jingles, podcasts, and audio content creation."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block bg-brand-accent/20 border border-brand-accent text-brand-accent px-6 py-2 rounded-full mb-8 animate-pulse">
        <span class="text-2xl font-bold uppercase tracking-wider">Coming Soon!</span>
      </div>
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Audio Branding</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Sound That Defines Your Brand
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Custom audio branding that makes your business memorable. From jingles to podcasts, we create sound that resonates.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="cta-glow-shine inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ What We Offer</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Audio Branding Services
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Custom Jingles</h3>
          <p class="text-brand-sky/70 text-sm">Catchy, memorable jingles that stick with your customers and reinforce brand recognition.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Professional Voiceovers</h3>
          <p class="text-brand-sky/70 text-sm">High-quality voiceover recordings for commercials, videos, and phone systems.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 001.414 1.414m2.828-9.9a9 9 0 012.828-2.828" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Sound Design</h3>
          <p class="text-brand-sky/70 text-sm">Custom sound effects and audio elements for videos, apps, and digital experiences.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Podcast Production</h3>
          <p class="text-brand-sky/70 text-sm">Full podcast production services from recording to editing and distribution.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Audio Identity</h3>
          <p class="text-brand-sky/70 text-sm">Complete audio branding strategy including sound logos and brand audio guidelines.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Multiple Formats</h3>
          <p class="text-brand-sky/70 text-sm">Audio delivered in all formats needed for web, radio, TV, and mobile applications.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Be Heard?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's create audio that makes your brand unforgettable. Get in touch today.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="cta-glow-shine inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
