---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Case Studies"
  description="View our case studies and see how we've helped local businesses grow online. Real results from real clients in Shelby, Charlotte, and surrounding areas."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Case Studies</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blue-light to-brand-sky">Real Results</span> for Real Businesses
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        See how we've helped local businesses transform their online presence and achieve measurable growth.
      </p>
    </div>
  </section>

  <!-- Case Studies Grid -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Solution A: Indexing Case Study -->
        <a href="/services/case-studies/solution-a" class="group bg-brand-darkest border border-brand-sky/20 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-500 block">
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-brand-blue/20 text-brand-blue text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full">Technical SEO</span>
              <span class="text-white/40 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-white/10">Solution A</span>
            </div>
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-white mb-4 group-hover:text-brand-sky transition-colors">
              Why Google's Not Indexing Your Website (And How Pre-Rendering Can Solve It)
            </h2>
            <p class="text-brand-sky/70 mb-6">
              How we fixed severe indexing issues on a brand-new AI-generated website so it could finally be found by search engines.
            </p>
            <div class="inline-flex items-center text-brand-cyan font-medium group-hover:gap-2 transition-all">
              Read Full Case Study <span class="ml-2">→</span>
            </div>
          </div>
        </a>

        <!-- Local SEO Case Study placeholder -->
        <div class="group bg-brand-darkest border border-brand-sky/20 rounded-2xl overflow-hidden hover:border-brand-sky/50 transition-all duration-500 block">
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-brand-blue/20 text-brand-blue text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full">Local SEO & Growth</span>
            </div>
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-white mb-4 group-hover:text-brand-sky transition-colors">
              How Service Area Pages Multiplied Organic Reach for a Local Agency
            </h2>
            <p class="text-brand-sky/70 mb-6">
              Creating city-specific service area pages increased organic impressions by 214% and inbound leads by 138% in just 4 months.
            </p>
            <div class="inline-flex items-center text-brand-cyan font-medium group-hover:gap-2 transition-all opacity-50">
              Coming Soon <span class="ml-2">→</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Want to See Your Results Here?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's work together to create your own success story. Get in touch today to get started.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
