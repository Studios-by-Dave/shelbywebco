---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Case Studies | Shelby Web Company"
  description="View our case studies and see how we've helped local businesses grow online. Real results from real clients in Shelby, Charlotte, and surrounding areas."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Case Studies</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Real Results for Real Businesses
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        See how we've helped local businesses transform their online presence and achieve measurable growth.
      </p>
    </div>
  </section>

  <!-- Coming Soon Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-12">
        <svg class="w-16 h-16 text-brand-cyan mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <h2 class="font-heading text-3xl font-bold text-white mb-4">
          Case Studies Coming Soon
        </h2>
        <p class="text-brand-sky/80 mb-8">
          We're currently building our portfolio of success stories. Check back soon to see detailed case studies of how we've helped businesses like yours succeed online.
        </p>
        <a 
          href="/contact#get-in-touch"
          class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
        >
          Be Our Next Success Story
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Want to See Your Results Here?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's work together to create your own success story. Get in touch today to get started.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-8 py-3 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
