---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Custom Media Packs"
  description="Custom media packs and digital content services in Shelby, NC. High-quality visuals, mockups, and digital assets tailored to your business. Fast turnaround and conversion-focused design."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4" data-animate>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Custom Media Packs</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Custom Digital <br/> <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blue-light to-brand-sky">Media & Assets</span>
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Take your marketing content to the next level with high-quality visual content that converts. From mockups to custom graphics, we create assets that separate you from the competition.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ What We Offer</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Custom Media Pack Services
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Custom Visuals & Graphics</h3>
          <p class="text-brand-sky/70 text-sm">Unique graphics and visuals designed specifically for your brand and marketing needs.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Website & Social Media Ready</h3>
          <p class="text-brand-sky/70 text-sm">All assets optimized for use across your website and all major social media platforms.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Fast Turnaround Delivery</h3>
          <p class="text-brand-sky/70 text-sm">Quick delivery without compromising quality. Get your media assets when you need them.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Conversion-Focused Design</h3>
          <p class="text-brand-sky/70 text-sm">Every element designed with conversion in mind to help you achieve your business goals.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Brand Consistent</h3>
          <p class="text-brand-sky/70 text-sm">All media assets align perfectly with your existing brand identity and guidelines.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Unlimited Revisions</h3>
          <p class="text-brand-sky/70 text-sm">We work with you until you're completely satisfied with every media asset.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-24 px-4 bg-brand-darkest" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-purple text-sm uppercase tracking-widest mb-4">✦ Investment Options</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">Choose Your Media Pack</h2>
        <p class="text-xl text-brand-sky/80 max-w-2xl mx-auto">
          Professional digital assets tailored to your business goals. Choose the package that fits your current needs.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 items-start">
        <!-- Starter Pack -->
        <div class="bg-brand-dark border border-white/10 rounded-3xl p-8 hover:border-brand-purple/50 transition-all duration-300 relative group">
          <div class="w-12 h-12 bg-brand-purple/10 rounded-2xl flex items-center justify-center mb-6 text-brand-purple group-hover:scale-110 transition-transform">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-white mb-2">Starter Pack</h3>
          <div class="mb-6 flex items-baseline gap-2">
            <span class="text-4xl font-black text-brand-blue-light">$149</span>
            <span class="text-brand-sky/40 text-sm">(one-time)</span>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              5 Custom Branded Images
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              1 Website or Social Media Mockup
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Basic Visual Styling
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              High-Resolution Files
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              2-3 Day Turnaround
            </li>
          </ul>
          <a href="/contact#get-in-touch" class="block w-full py-4 bg-white/5 border border-white/10 rounded-xl text-white font-bold text-center hover:bg-brand-blue-light hover:border-brand-blue-light transition-all">Order Your Pack</a>
        </div>

        <!-- Growth Pack -->
        <div class="bg-brand-dark border-2 border-brand-accent rounded-3xl p-8 hover:shadow-[0_0_40px_rgba(132,204,22,0.15)] transition-all duration-300 relative lg:-mt-4 lg:mb-4">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-accent text-[#0A0A0A] text-xs font-black px-4 py-1.5 rounded-full uppercase tracking-widest">
            Most Popular
          </div>
          <div class="w-12 h-12 bg-brand-accent/10 rounded-2xl flex items-center justify-center mb-6 text-brand-accent">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-white mb-2">Growth Pack</h3>
          <div class="mb-6 flex items-baseline gap-2">
            <span class="text-4xl font-black text-brand-accent">$249</span>
            <span class="text-brand-sky/40 text-sm">(one-time)</span>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3 text-white text-sm font-medium">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              10 Custom Branded Images
            </li>
            <li class="flex items-start gap-3 text-white text-sm font-medium">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              2 Premium Mockups
            </li>
            <li class="flex items-start gap-3 text-white text-sm font-medium">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Light Prototype/Layout Preview
            </li>
            <li class="flex items-start gap-3 text-white text-sm font-medium">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              2 Revisions Included
            </li>
            <li class="flex items-start gap-3 text-white text-sm font-medium">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Priority 48-Hour Delivery
            </li>
          </ul>
          <a href="/contact#get-in-touch" class="block w-full py-4 bg-brand-accent text-[#0A0A0A] rounded-xl font-bold text-center hover:bg-brand-accent-light transition-all shadow-[0_0_20px_rgba(132,204,22,0.3)]">Order Your Pack</a>
        </div>

        <!-- Premium Pack -->
        <div class="bg-brand-dark border border-white/10 rounded-3xl p-8 hover:border-brand-blue/50 transition-all duration-300 group">
          <div class="w-12 h-12 bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-6 text-brand-blue group-hover:scale-110 transition-transform">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-white mb-2">Premium Pack</h3>
          <div class="mb-6 flex items-baseline gap-2">
            <span class="text-4xl font-black text-brand-blue">$399</span>
            <span class="text-brand-sky/40 text-sm">(one-time)</span>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              20 Fully Custom Assets
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              3-5 Advanced Mockups
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Full Brand Styling & Strategy
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              3 Revisions Included
            </li>
            <li class="flex items-start gap-3 text-brand-sky/70 text-sm">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5 text-brand-accent shrink-0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Bonus: 1 Custom Hero Design
            </li>
          </ul>
          <a href="/contact#get-in-touch" class="block w-full py-4 bg-white/5 border border-white/10 rounded-xl text-white font-bold text-center hover:bg-brand-blue hover:border-brand-blue transition-all">Order Your Pack</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready for Custom Media?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's create stunning digital assets that elevate your brand. Get in touch today.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light shadow-[0_0_15px_rgba(132,204,22,0.3)] transition-all duration-300"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
