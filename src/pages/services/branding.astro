---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixieDust from '../../components/PixieDust.jsx';
---

<BaseLayout 
  title="Logo Design & Branding"
  description="Professional logo design and branding services in Shelby, NC. Custom logos, brand identity packages, business cards, and social media assets that make your business stand out."
>

  <!-- Hero Section -->
  <section class="py-20 lg:py-32 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 z-0 pointer-events-none">
      <PixieDust client:load />
    </div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Brand Identity</p>
      <h1 class="font-heading text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Logo Design & <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-blue-light to-brand-sky">Branding Solutions</span>
      </h1>
      <p class="text-xl text-brand-sky/80 mb-8">
        Professional branding that makes your business stand out. From logos to complete brand identity packages, we create memorable brands for local businesses.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="cta-glow-shine inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4 bg-brand-dark" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ What We Offer</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Professional Branding Services
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Custom Logo Design</h3>
          <p class="text-brand-sky/70 text-sm">Unique, memorable logos that capture your brand's essence and resonate with your target audience.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Brand Identity Package</h3>
          <p class="text-brand-sky/70 text-sm">Complete brand guidelines including color palettes, typography, and usage guidelines for consistent branding.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Business Card Design</h3>
          <p class="text-brand-sky/70 text-sm">Professional business cards that make a lasting impression and reinforce your brand identity.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Social Media Assets</h3>
          <p class="text-brand-sky/70 text-sm">Custom profile pictures, cover images, and post templates optimized for all major social platforms.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Brand Guidelines</h3>
          <p class="text-brand-sky/70 text-sm">Comprehensive documentation on how to use your brand assets correctly across all media.</p>
        </div>

        <div class="bg-brand-darkest border border-brand-sky/40 rounded-xl p-6 hover:shadow-[0_0_20px_rgba(0,200,255,0.15)] transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-sky to-brand-cyan rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">Multiple Revisions</h3>
          <p class="text-brand-sky/70 text-sm">We work with you until you're completely satisfied with your brand identity.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 px-4 bg-brand-darkest" data-animate>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-glow text-sm uppercase tracking-widest mb-4">✦ Branding Packages</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          Three Branding Tiers Built for Every Business
        </h2>
        <p class="max-w-3xl mx-auto text-brand-sky/70 text-lg">
          Choose the level of brand support that fits your project. Each package is designed to help local businesses build trust, stand out, and grow with stronger visual identity.
        </p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">
        <div class="bg-brand-dark border border-brand-blue/20 rounded-3xl p-8 shadow-xl hover:border-brand-cyan/40 transition-all duration-300">
          <div class="text-brand-cyan font-bold uppercase tracking-[0.3em] text-xs mb-4">Starter</div>
          <h3 class="font-heading text-3xl font-bold text-white mb-4">Essential Brand Kit</h3>
          <div class="text-[#f3db70] text-4xl md:text-5xl font-black font-nav drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] mb-6">$699</div>
          <p class="text-brand-sky/70 mb-8">Perfect for new businesses that need a strong logo and brand foundation without extra bells and whistles.</p>
          <ul class="space-y-4 mb-8 text-brand-sky/70 text-sm">
            <li>• 3 custom logo concepts</li>
            <li>• Primary logo + simplified mark</li>
            <li>• Color palette & typography selection</li>
            <li>• Basic brand usage guide</li>
            <li>• Business card design concept</li>
          </ul>
          <a href="/contact#get-in-touch" class="inline-flex items-center justify-center w-full bg-brand-accent text-[#0A0A0A] py-3 rounded-full font-semibold hover:bg-brand-accent-light transition-colors duration-300">
            Start with Essentials
          </a>
        </div>

        <div class="bg-brand-dark border border-brand-blue/20 rounded-3xl p-8 shadow-2xl ring-2 ring-brand-cyan/20">
          <div class="text-brand-cyan font-bold uppercase tracking-[0.3em] text-xs mb-4">Growth</div>
          <h3 class="font-heading text-3xl font-bold text-white mb-4">Complete Brand Suite</h3>
          <div class="text-[#f3db70] text-4xl md:text-5xl font-black font-nav drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] mb-6">$1,099</div>
          <p class="text-brand-sky/70 mb-8">For businesses that want a full identity system ready to launch across digital and print channels.</p>
          <ul class="space-y-4 mb-8 text-brand-sky/70 text-sm">
            <li>• 5+ logo variations and layout lockups</li>
            <li>• Full brand guidelines with usage rules</li>
            <li>• Social media profile + post templates</li>
            <li>• Email signature & favicon assets</li>
            <li>• Up to 4 revision rounds</li>
          </ul>
          <a href="/contact#get-in-touch" class="inline-flex items-center justify-center w-full bg-brand-accent text-[#0A0A0A] py-3 rounded-full font-semibold hover:bg-brand-accent-light transition-colors duration-300">
            Choose Complete Suite
          </a>
        </div>

        <div class="bg-brand-dark border border-brand-blue/20 rounded-3xl p-8 shadow-xl hover:border-brand-cyan/40 transition-all duration-300">
          <div class="text-brand-cyan font-bold uppercase tracking-[0.3em] text-xs mb-4">Premium</div>
          <h3 class="font-heading text-3xl font-bold text-white mb-4">Brand & Wrap Package</h3>
          <div class="text-[#f3db70] text-4xl md:text-5xl font-black font-nav drop-shadow-[0_2px_2px_rgba(243,219,112,0.5)] mb-6">$1,998</div>
          <p class="text-brand-sky/70 mb-8">Ideal for established brands that need an elevated visual system plus fleet and vehicle branding support.</p>
          <ul class="space-y-4 mb-8 text-brand-sky/70 text-sm">
            <li>• Everything in the Complete Brand Suite</li>
            <li>• Custom vehicle wrap and fleet graphics concepts</li>
            <li>• Exterior signage & storefront design mockups</li>
            <li>• Marketing collateral templates</li>
            <li>• Extended brand launch support</li>
          </ul>
          <a href="/contact#get-in-touch" class="inline-flex items-center justify-center w-full bg-brand-accent text-[#0A0A0A] py-3 rounded-full font-semibold hover:bg-brand-accent-light transition-colors duration-300">
            Build Premium Brand
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 relative overflow-hidden" data-animate>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-darkest via-brand-dark to-brand-darkest"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-sky/10 to-brand-cyan/10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Build Your Brand?
      </h2>
      <p class="text-lg text-brand-sky/80 mb-8">
        Let's create a brand identity that sets you apart from the competition. Get in touch today.
      </p>
      <a 
        href="/contact#get-in-touch"
        class="cta-glow-shine inline-block bg-brand-accent text-[#0A0A0A] px-8 py-3 rounded-lg font-medium hover:bg-brand-accent-light"
      >
        Get Started Today
      </a>
    </div>
  </section>

</BaseLayout>
