---
import { Image } from 'astro:assets';
import logo from '../../assets/SWeblogo1.jpg';
---

<footer class="bg-brand-darkest border-t border-brand-sky/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="space-y-4">
        <div class="flex items-center space-x-3">
          <Image 
            src={logo} 
            alt="Shelby Web Company Logo" 
            width={48} 
            height={48}
            class="h-12 w-auto"
          />
        </div>
        <p class="text-brand-sky/80 text-sm">CompTIA A+ Certified</p>
        <div class="space-y-2 text-sm text-brand-sky/70">
          <p>
            <a href="tel:+17044738188" class="hover:text-brand-glow transition-colors">
              (704) 473-8188
            </a>
          </p>
          <p>
            <a href="mailto:dx1creations25@gmail.com" class="hover:text-brand-glow transition-colors">
              dx1creations25@gmail.com
            </a>
          </p>
          <p>Shelby, NC</p>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-heading text-lg font-bold text-white mb-4">Services</h3>
        <ul class="space-y-2 text-sm text-brand-sky/70">
          <li><a href="/services/web-design" class="hover:text-brand-glow transition-colors">Web Design</a></li>
          <li><a href="/services/branding" class="hover:text-brand-glow transition-colors">Logo Design & Branding</a></li>
          <li><a href="/services/seo" class="hover:text-brand-glow transition-colors">SEO Services</a></li>
          <li><a href="/services/media-packs" class="hover:text-brand-glow transition-colors">Custom Media Packs</a></li>
          <li><a href="/services/audio-branding" class="hover:text-brand-glow transition-colors">Audio Branding</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-heading text-lg font-bold text-white mb-4">Company</h3>
        <ul class="space-y-2 text-sm text-brand-sky/70">
          <li><a href="/about" class="hover:text-brand-glow transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-brand-glow transition-colors">Contact</a></li>
          <li><a href="/blog" class="hover:text-brand-glow transition-colors">Blog</a></li>
          <li><a href="/privacy" class="hover:text-brand-glow transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-brand-glow transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h3 class="font-heading text-lg font-bold text-white mb-4">Ready to Get Started?</h3>
        <p class="text-sm text-brand-sky/70 mb-4">
          Let's build your online engine and get your business found, trusted, and hired!
        </p>
        <a
          href="/contact#get-in-touch"
          class="inline-block bg-gradient-to-r from-brand-sky to-brand-cyan text-white px-6 py-2.5 rounded-lg font-medium hover:shadow-[0_0_20px_rgba(0,200,255,0.3)] transition-all duration-300"
        >
          Get Your Free Quote
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-brand-sky/20">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-sm text-brand-sky/60">
          © 2026 Shelby Web Company. All rights reserved.
        </p>
        <p class="text-sm text-brand-sky/60">
          Built with ❤️ for local businesses
        </p>
        <div class="flex space-x-4">
          <!-- Facebook -->
          <a href="#" class="text-brand-sky/60 hover:text-brand-glow transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" class="text-brand-sky/60 hover:text-brand-glow transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="#" class="text-brand-sky/60 hover:text-brand-glow transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
