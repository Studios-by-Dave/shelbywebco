---
import { Image } from 'astro:assets';
import logo from '../../assets/SWeblogo1.jpg';
import MobileNav from './MobileNav.jsx';
import DesktopNav from './DesktopNav.jsx';
---

<nav class="sticky top-0 z-50 bg-brand-darkest border-b border-brand-purple/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3">
        <Image 
          src={logo} 
          alt="Shelby Web Company Logo" 
          width={56} 
          height={56}
          class="h-14 w-auto"
        />
        <span class="font-heading text-2xl font-bold text-white hidden sm:block">Shelby Web Co.</span>
      </a>

      <!-- Desktop Navigation -->
      <DesktopNav client:load />

      <!-- CTA Button & Phone -->
      <div class="hidden md:flex items-center space-x-4">
        <a 
          href="tel:+17044738188" 
          class="bg-brand-dark border border-brand-purple/30 rounded-lg px-4 py-2 hover:border-brand-green/50 transition-all duration-300 group"
        >
          <p class="text-brand-purple text-xs font-bold uppercase tracking-wider group-hover:text-brand-green transition-colors">Call Us Text Us</p>
          <p class="text-brand-green text-lg font-bold group-hover:text-brand-greenLight transition-colors">(704) 473-8188</p>
          <p class="text-white/60 text-xs">We're here 24/7</p>
        </a>
        <a 
          href="/contact#get-in-touch" 
          class="bg-brand-green text-white px-6 py-2.5 rounded-lg font-medium hover:bg-brand-greenLight transition-all duration-300"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <MobileNav client:load />
      </div>
    </div>
  </div>
</nav>
