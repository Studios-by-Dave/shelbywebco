---
import { Image } from 'astro:assets';
import logo from '../../assets/SWeblogo1.jpg';
import MobileNav from './MobileNav.jsx';
import DesktopNav from './DesktopNav.jsx';
---

<nav class="sticky top-0 z-50 bg-brand-darkest/80 backdrop-blur-md border-b border-brand-blue/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3">
        <Image 
          src={logo} 
          alt="Shelby Web Company Logo" 
          width={168}
          height={112}
          class="h-14 w-auto"
        />
        <span class="font-heading text-2xl font-bold text-white hidden sm:block">Shelby Web Company</span>
      </a>

      <!-- Desktop Navigation -->
      <DesktopNav client:load />

      <!-- Navbar Get Started Button -->
      <div class="hidden md:flex items-center space-x-6">
        <a 
          href="/contact#get-in-touch" 
          class="bg-brand-cyan text-white px-6 py-2.5 rounded-lg font-medium hover:bg-brand-cyanLight transition-all duration-300"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <MobileNav client:load />
      </div>
    </div>
  </div>
</nav>
