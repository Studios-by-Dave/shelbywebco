---
import { Image } from 'astro:assets';
import logo from '../../assets/SWeblogo1.jpg';
import MobileNav from './MobileNav.jsx';
import DesktopNav from './DesktopNav.jsx';
import PixieDust from './PixieDust.jsx';
---

<nav class="sticky top-0 z-50 bg-brand-darkest/80 backdrop-blur-md border-b border-brand-blue/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3">
        <Image 
          src={logo} 
          alt="Shelby Web Company Logo" 
          width={168}
          height={112}
          class="h-14 w-auto"
        />
        <span class="font-heading text-2xl font-bold text-white hidden sm:block">Shelby Web Company</span>
      </a>

      <!-- Desktop Navigation -->
      <DesktopNav client:load />

      <!-- Navbar Get Started Button -->
      <div class="hidden md:flex items-center space-x-6 relative group overflow-hidden">
        <a 
          href="/contact" 
          class="cta-shine bg-gradient-to-r from-brand-accent via-brand-accent-light to-brand-accent text-[#0A0A0A] px-5 py-2 rounded-md font-bold hover:shadow-[0_0_20px_rgba(132,204,22,0.5)] transition-all duration-300 relative z-10"
        >
          <span class="text-lg">Get Started</span>
          <div class="cta-shine-sweep absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
        </a>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-0">
          <PixieDust client:load />
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <MobileNav client:load />
      </div>
    </div>
  </div>
</nav>

<style>
  @keyframes ctaGlowPulse {
    0%,
    100% {
      box-shadow: 0 0 0 rgba(132, 204, 22, 0.0), 0 0 14px rgba(132, 204, 22, 0.26);
    }
    50% {
      box-shadow: 0 0 0 rgba(132, 204, 22, 0.0), 0 0 22px rgba(132, 204, 22, 0.38);
    }
  }

  @keyframes ctaSweep {
    0% {
      transform: translateX(-130%);
      opacity: 0;
    }
    15% {
      opacity: 0.35;
    }
    45% {
      transform: translateX(130%);
      opacity: 0;
    }
    100% {
      transform: translateX(130%);
      opacity: 0;
    }
  }

  .cta-shine {
    overflow: hidden;
    animation: ctaGlowPulse 2.8s ease-in-out infinite;
  }

  .cta-shine-sweep {
    animation: ctaSweep 4.6s ease-in-out infinite;
    pointer-events: none;
  }
</style>
