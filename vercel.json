{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/blog/why-choose-studios-by-dave",
      "destination": "/blog/why-choose-shelby-web-company",
      "permanent": true
    },
    {
      "source": "/why-choose-us",
      "destination": "/blog/why-choose-shelby-web-company",
      "permanent": true
    },
    {
      "source": "/studios",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/services/web-development",
      "destination": "/services/web-design",
      "permanent": true
    },
    {
      "source": "/services/logo-design",
      "destination": "/services/branding",
      "permanent": true
    },
    {
      "source": "/case-studies",
      "destination": "/services/case-studies",
      "permanent": true
    }
  ]
}
