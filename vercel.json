{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
  ,
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/favicon.jpg" },
    { "source": "/favicon-16.png", "destination": "/favicon.jpg" },
    { "source": "/favicon-32.png", "destination": "/favicon.jpg" },
    { "source": "/favicon-48.png", "destination": "/favicon.jpg" },
    { "source": "/favicon-96.png", "destination": "/favicon.jpg" },
    { "source": "/favicon-180.png", "destination": "/favicon.jpg" },
    { "source": "/favicon-192.png", "destination": "/favicon.jpg" },
    { "source": "/favicon-512.png", "destination": "/favicon.jpg" }
  ]
}
